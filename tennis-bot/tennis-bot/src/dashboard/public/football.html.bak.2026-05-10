<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Football Telegram Bot</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{--bg:#0d1117;--surface:#161b22;--surface2:#1c2128;--border:#30363d;--text:#e6edf3;--muted:#8b949e;--green:#3fb950;--red:#f85149;--blue:#58a6ff;--orange:#f0883e;--yellow:#e3b341;--purple:#bc8cff;}
html,body{height:100%;overflow:hidden}
body{background:var(--bg);color:var(--text);font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;display:flex;flex-direction:column}

/* Header */
.hdr{background:var(--surface);border-bottom:1px solid var(--border);flex-shrink:0}
.hdr-top{padding:9px 18px;display:flex;align-items:center;gap:12px;flex-wrap:wrap}
.hdr h1{font-size:15px;font-weight:700;white-space:nowrap}.hdr h1 span{color:var(--blue)}
.tabs{display:flex;gap:2px;background:var(--surface2);border:1px solid var(--border);border-radius:7px;padding:2px}
.tab{padding:4px 13px;border-radius:5px;border:none;background:none;color:var(--muted);cursor:pointer;font-size:12px;font-weight:600;transition:all .15s}
.tab.active{background:var(--blue);color:#fff}
.hdr-r{display:flex;align-items:center;gap:7px;margin-left:auto;flex-wrap:wrap}
.live-dot{width:7px;height:7px;border-radius:50%;background:var(--green);animation:pulse 2s infinite;flex-shrink:0}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.4;transform:scale(.85)}}
.upd{font-size:11px;color:var(--muted);white-space:nowrap}
.btn{background:none;border:1px solid var(--border);color:var(--muted);padding:5px 10px;border-radius:6px;cursor:pointer;font-size:11px;font-weight:600;transition:all .15s;white-space:nowrap}
.btn:hover{border-color:var(--blue);color:var(--blue)}.btn:disabled{opacity:.45;cursor:not-allowed}
.btn.hi{border-color:rgba(88,166,255,.4);color:var(--blue)}
.bell{font-size:14px;cursor:pointer;opacity:.55;border:none;background:none;transition:opacity .2s}.bell:hover,.bell.on{opacity:1}

/* Toast */
.toast-wrap{position:fixed;bottom:20px;right:20px;display:flex;flex-direction:column;gap:8px;z-index:999;pointer-events:none}
.toast{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:12px 16px;min-width:255px;max-width:330px;pointer-events:all;animation:slideIn .3s ease;box-shadow:0 8px 24px rgba(0,0,0,.4);position:relative}
.toast.placed{border-left:4px solid var(--blue)}.toast.failed{border-left:4px solid var(--red)}
.toast-title{font-size:13px;font-weight:700;margin-bottom:4px}.toast-body{font-size:12px;color:var(--muted);line-height:1.5}
.toast-close{position:absolute;top:7px;right:9px;background:none;border:none;color:var(--muted);cursor:pointer;font-size:13px}
@keyframes slideIn{from{transform:translateX(120%);opacity:0}to{transform:translateX(0);opacity:1}}

/* Layout */
.view{display:flex;flex:1;overflow:hidden;min-height:0}.view.hidden{display:none}

/* Left panel */
.left{width:360px;min-width:240px;display:flex;flex-direction:column;border-right:1px solid var(--border);overflow:hidden}
.filters{padding:8px 11px;border-bottom:1px solid var(--border);background:var(--surface2);display:flex;flex-direction:column;gap:6px}
.filter-row{display:flex;gap:6px}
input[type=text],select{background:var(--surface);border:1px solid var(--border);color:var(--text);padding:5px 8px;border-radius:6px;font-size:12px;outline:none;width:100%}
input[type=text]:focus,select:focus{border-color:var(--blue)}select{cursor:pointer}
.bet-list{overflow-y:auto;flex:1}
.no-bets{padding:28px;text-align:center;color:var(--muted);font-size:13px}

/* Bet cards */
.bet-card{padding:10px 13px;border-bottom:1px solid var(--border);cursor:pointer;transition:background .12s;border-left:3px solid transparent}
.bet-card:hover{background:var(--surface2)}.bet-card.active{background:var(--surface2);border-left-color:var(--blue)}
.bet-card.ow{border-left-color:var(--green)}.bet-card.ol{border-left-color:var(--red)}
.bc-top{display:flex;align-items:flex-start;justify-content:space-between;gap:6px;margin-bottom:4px}
.bc-match{font-size:12px;font-weight:600;line-height:1.3;flex:1}
.badges{display:flex;gap:3px;flex-wrap:wrap;justify-content:flex-end}
.badge{font-size:10px;font-weight:700;padding:2px 6px;border-radius:8px;white-space:nowrap}
.badge-ok{background:rgba(63,185,80,.12);color:var(--green);border:1px solid rgba(63,185,80,.3)}
.badge-fail{background:rgba(248,81,73,.12);color:var(--red);border:1px solid rgba(248,81,73,.3)}
.badge-comp{background:rgba(188,140,255,.12);color:var(--purple);border:1px solid rgba(188,140,255,.3)}
.badge-won{background:rgba(63,185,80,.18);color:var(--green);border:1px solid rgba(63,185,80,.5)}
.badge-lost{background:rgba(248,81,73,.18);color:var(--red);border:1px solid rgba(248,81,73,.5)}
.badge-pending{background:rgba(139,148,158,.1);color:var(--muted);border:1px solid rgba(139,148,158,.3)}
.del-fb-btn{background:none;border:1px solid rgba(139,148,158,.3);color:var(--muted);border-radius:4px;padding:1px 4px;cursor:pointer;font-size:10px;line-height:1.4}.del-fb-btn:hover{background:rgba(248,81,73,.15);color:var(--red);border-color:var(--red)}
.bc-meta{display:flex;align-items:center;gap:6px;flex-wrap:wrap}
.bc-time{font-size:10px;color:var(--muted)}.strat-pill{font-size:10px;font-weight:700;padding:1px 5px;border-radius:4px;background:rgba(88,166,255,.12);color:var(--blue);border:1px solid rgba(88,166,255,.3)}
.bc-market{font-size:10px;color:var(--muted)}.bc-odds{font-size:12px;font-weight:700;color:var(--orange);margin-left:auto}

/* Right panel */
.right{flex:1;overflow-y:auto;padding:14px 18px;min-width:0}
.empty{display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;color:var(--muted);gap:10px}.empty-icon{font-size:42px}
.match-hdr{margin-bottom:10px}
.match-name-row{display:flex;align-items:flex-start;justify-content:space-between;gap:10px;margin-bottom:5px}
.match-name{font-size:17px;font-weight:700;line-height:1.2;flex:1}
.match-badges{display:flex;gap:4px;flex-wrap:wrap;flex-shrink:0}
.match-sub{display:flex;gap:10px;flex-wrap:wrap;font-size:11px;color:var(--muted);align-items:center}
/* Compact stats strip */
.detail-strip{display:flex;background:var(--surface);border:1px solid var(--border);border-radius:8px;margin-bottom:11px;overflow:hidden;flex-shrink:0}
.ds-cell{flex:1;padding:8px 6px;border-right:1px solid var(--border);text-align:center;min-width:0}
.ds-cell:last-child{border-right:none}
.ds-lbl{font-size:9px;color:var(--muted);text-transform:uppercase;letter-spacing:.3px;margin-bottom:3px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.ds-val{font-size:14px;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
/* Two-column detail body */
.detail-cols{display:grid;grid-template-columns:5fr 7fr;gap:11px;margin-bottom:11px;align-items:start}
.detail-left{display:flex;flex-direction:column;gap:11px}
/* Side-by-side tables */
.detail-foot{display:grid;grid-template-columns:1fr 1fr;gap:11px}
.section{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:11px 13px;margin-bottom:0}
.sec-title{font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.6px;margin-bottom:9px;display:flex;align-items:center;justify-content:space-between}
.chart-wrap{position:relative;height:190px}
.chart-wrap-lg{position:relative;height:100%;min-height:260px}
.chart-note{padding:16px 0;text-align:center;color:var(--muted);font-size:12px;line-height:1.8}
table{width:100%;border-collapse:collapse;font-size:12px}
th{text-align:left;padding:5px 9px;color:var(--muted);font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:.4px;border-bottom:1px solid var(--border)}
td{padding:6px 9px;border-bottom:1px solid rgba(48,54,61,.4)}tr:last-child td{border-bottom:none}
.mono{font-family:'Consolas','Courier New',monospace;color:var(--muted);font-size:11px}
.result-row{display:flex;gap:8px;align-items:flex-end;flex-wrap:wrap}
.result-row input[type=number]{width:54px;padding:5px 7px;text-align:center}
.rbtn{padding:5px 11px;border-radius:6px;border:none;cursor:pointer;font-size:12px;font-weight:600;transition:all .15s}
.fetch-btn{background:rgba(88,166,255,.12);color:var(--blue);border:1px solid rgba(88,166,255,.3)}.fetch-btn:hover{background:rgba(88,166,255,.2)}.fetch-btn:disabled{opacity:.5;cursor:not-allowed}
.save-btn{background:var(--green);color:#000}
.r-lbl{font-size:11px;color:var(--muted);margin-bottom:3px}
.rmsg{font-size:11px;margin-top:6px;padding:5px 9px;border-radius:6px}.rmsg.ok{background:rgba(63,185,80,.1);color:var(--green)}.rmsg.err{background:rgba(248,81,73,.1);color:var(--red)}
.score-chip{display:inline-flex;gap:4px;align-items:center;background:var(--surface2);border:1px solid var(--border);border-radius:5px;padding:2px 7px;font-size:12px;font-weight:700}

/* Bets panel right-side dashboard */
.bp-stats{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:12px}
.bp-stat{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:9px 12px;text-align:center;flex:1;min-width:72px}
.bp-stat-val{font-size:19px;font-weight:800;line-height:1;margin-bottom:2px}
.bp-stat-lbl{font-size:9px;color:var(--muted);text-transform:uppercase;letter-spacing:.5px}
.bp-charts-row{display:grid;grid-template-columns:1fr 1fr;gap:11px;margin-bottom:11px}
tr.selected-row td{background:rgba(88,166,255,.07)}

/* Per-bet context bars */
.ctx-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:4px}
.ctx-card{background:var(--surface2);border:1px solid var(--border);border-radius:7px;padding:10px 12px}
.ctx-label{font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.4px;margin-bottom:5px}
.ctx-val{font-size:16px;font-weight:800;margin-bottom:2px}
.ctx-sub{font-size:11px;color:var(--muted)}
.bar-track{height:5px;background:var(--surface);border-radius:3px;margin-top:6px;overflow:hidden}
.bar-fill{height:100%;border-radius:3px;transition:width .6s ease}
.ctx-odds-row{display:flex;align-items:center;gap:8px;font-size:12px;margin-top:8px;padding-top:8px;border-top:1px solid var(--border)}
.odds-marker{flex:1;height:4px;background:var(--surface);border-radius:2px;position:relative;overflow:visible}
.odds-marker-dot{width:10px;height:10px;border-radius:50%;background:var(--orange);position:absolute;top:-3px;transform:translateX(-50%);transition:left .6s}

/* Analytics */
.analytics-wrap{display:flex;flex:1;overflow:hidden;min-height:0}
.a-main{flex:1;overflow-y:auto;padding:16px 20px}
.a-sidebar{width:280px;border-left:1px solid var(--border);overflow-y:auto;background:var(--surface2);flex-shrink:0;display:flex;flex-direction:column}
.a-sidebar.hidden{display:none}
.a-sb-hdr{padding:12px 14px;border-bottom:1px solid var(--border);font-size:12px;font-weight:700;display:flex;align-items:center;justify-content:space-between}
.a-sb-body{padding:10px;flex:1;overflow-y:auto}
.chart-toggle{display:flex;align-items:center;gap:8px;padding:9px 10px;border-radius:7px;cursor:grab;margin-bottom:4px;border:1px solid transparent;transition:background .12s;user-select:none}
.chart-toggle:hover{background:var(--surface);border-color:var(--border)}
.chart-toggle.dragging{opacity:.5;cursor:grabbing}
.chart-toggle input[type=checkbox]{cursor:pointer;width:15px;height:15px;accent-color:var(--blue)}
.ct-label{font-size:12px;font-weight:600;flex:1}
.ct-desc{font-size:10px;color:var(--muted)}
.drag-handle{color:var(--muted);font-size:14px;cursor:grab}
.a-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(380px,1fr));gap:14px}
.chart-card{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:14px}
.cct{font-size:11px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;margin-bottom:12px}
.chart-card .chart-wrap{height:240px}.chart-card.tall .chart-wrap{height:310px}
.sum-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(120px,1fr));gap:8px;margin-bottom:14px}
.sum-card{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:10px 12px}
.sc-val{font-size:20px;font-weight:800;margin-bottom:2px}.sc-lbl{font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.4px}
.toggle-lbl{display:flex;align-items:center;gap:5px;font-size:11px;color:var(--muted);cursor:pointer}
.toggle-lbl input{cursor:pointer}
.a-mkt-bar{display:flex;gap:5px;padding:12px 0 4px;flex-shrink:0;flex-wrap:wrap}
.mf-btn{padding:5px 14px;border-radius:6px;border:1px solid var(--border);background:var(--surface);color:var(--muted);cursor:pointer;font-size:12px;font-weight:600;transition:all .15s}
.mf-btn.active{background:var(--blue);color:#fff;border-color:var(--blue)}
.mf-btn:hover:not(.active){border-color:var(--blue);color:var(--blue)}

::-webkit-scrollbar{width:5px}::-webkit-scrollbar-track{background:transparent}::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px}
@media(max-width:700px){.view{flex-direction:column}.left{width:100%;height:40vh;border-right:none;border-bottom:1px solid var(--border)}.right,.a-main{height:60vh;padding:12px}html,body{overflow:auto;height:auto}.a-grid{grid-template-columns:1fr}.a-sidebar{width:100%;border-left:none;border-top:1px solid var(--border)}.detail-cols,.detail-foot{grid-template-columns:1fr}}
@media(max-width:1100px){.detail-cols{grid-template-columns:1fr 1fr}}
/* SportMonks tab */
.sm-status-bar{display:flex;align-items:center;gap:16px;background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:8px 14px;margin-bottom:14px;flex-wrap:wrap}
.sm-status-item{display:flex;align-items:center;gap:4px}
.sm-status-dot{width:8px;height:8px;border-radius:50%;background:var(--muted);flex-shrink:0}
.sm-status-dot.live{background:var(--green);box-shadow:0 0 6px var(--green);animation:pulse 2s infinite}
.sm-status-dot.warn{background:var(--yellow)}
.sm-tbl{width:100%;border-collapse:collapse;font-size:11px;white-space:nowrap}
.sm-tbl th{background:var(--surface2);color:var(--muted);font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;padding:6px 10px;border-bottom:1px solid var(--border);text-align:left;cursor:default}
.sm-tbl th[title]{text-decoration:underline dotted;cursor:help}
.sm-tbl td{padding:7px 10px;border-bottom:1px solid rgba(48,54,61,.6);vertical-align:middle}
.sm-tbl tr:last-child td{border-bottom:none}
.sm-tbl tr:hover td{background:var(--surface2)}
.sm-xg-hi{color:var(--orange);font-weight:700}
.sm-xg-lo{color:var(--muted)}
.sm-press-hi{color:var(--blue);font-weight:700}
.sm-signal-pill{display:inline-block;font-size:9px;font-weight:700;padding:1px 5px;border-radius:8px;background:rgba(248,81,73,.15);color:var(--red);border:1px solid rgba(248,81,73,.3);margin:1px}
.sm-strat-ref{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:10px}
.sm-strat-card{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:12px 14px}
.sm-strat-card.disabled{opacity:.45}
.sm-strat-name{font-size:12px;font-weight:700;margin-bottom:4px;display:flex;align-items:center;gap:6px}
.sm-strat-desc{font-size:11px;color:var(--muted);margin-bottom:8px}
.sm-strat-params{display:flex;flex-wrap:wrap;gap:4px}
.sm-param{font-size:10px;background:var(--surface2);border:1px solid var(--border);border-radius:4px;padding:2px 6px;color:var(--muted)}.sm-param strong{color:var(--text)}
/* Fixture rows � collapsed list */
.sm-fixture-list{border:1px solid var(--border);border-radius:8px;overflow:hidden}
.sm-row{background:var(--surface);border-bottom:1px solid var(--border);cursor:pointer;transition:background .1s}
.sm-row:last-child{border-bottom:none}
.sm-row:hover .sm-row-hdr{background:rgba(255,255,255,.03)}
.sm-row.open .sm-row-hdr{background:rgba(88,166,255,.06)}
.sm-row-hdr{display:flex;align-items:center;gap:8px;padding:9px 13px;flex-wrap:wrap}
.sm-row-minute{font-size:11px;font-weight:800;color:var(--yellow);background:rgba(227,179,65,.12);border:1px solid rgba(227,179,65,.25);border-radius:12px;padding:1px 8px;white-space:nowrap;flex-shrink:0}
.sm-row-teams{flex:1;font-size:13px;font-weight:700;display:flex;align-items:center;gap:6px;min-width:0}
.sm-row-score{font-size:14px;font-weight:800;background:var(--surface2);border:1px solid var(--border);border-radius:5px;padding:1px 8px;white-space:nowrap;flex-shrink:0}
.sm-row-inline{display:flex;align-items:center;gap:10px;flex-shrink:0;flex-wrap:wrap}
.sm-inline-stat{display:flex;flex-direction:column;align-items:center;min-width:52px}
.sm-inline-lbl{font-size:8px;color:var(--muted);text-transform:uppercase;letter-spacing:.3px}
.sm-inline-val{font-size:11px;font-weight:700}
.sm-inline-bar{display:flex;height:3px;border-radius:2px;overflow:hidden;background:rgba(255,255,255,.06);width:52px;margin-top:2px}
.sm-inline-bar-h{height:100%;background:var(--blue)}
.sm-inline-bar-a{height:100%;background:var(--orange)}
.sm-row-sigs{display:flex;gap:3px;flex-wrap:wrap;flex-shrink:0}
.sm-row-chevron{color:var(--muted);font-size:11px;flex-shrink:0;transition:transform .2s}
.sm-row.open .sm-row-chevron{transform:rotate(180deg)}
/* Expanded detail panel */
.sm-row-detail{display:none;border-top:1px solid var(--border);background:rgba(0,0,0,.2)}
.sm-row.open .sm-row-detail{display:block}
.sm-detail-grid{display:grid;grid-template-columns:1fr 1fr;gap:0}
.sm-detail-col{padding:10px 14px}
.sm-detail-col:first-child{border-right:1px solid var(--border)}
.sm-detail-stat{display:flex;flex-direction:column;gap:3px;margin-bottom:8px;padding:6px 8px;border-radius:6px;background:rgba(255,255,255,.02)}
.sm-detail-stat:last-child{margin-bottom:0}
.sm-detail-stat.alert-xg{background:rgba(240,136,62,.07);border:1px solid rgba(240,136,62,.2)}
.sm-detail-stat.alert-press{background:rgba(88,166,255,.06);border:1px solid rgba(88,166,255,.2)}
.sm-ds-lbl{display:flex;justify-content:space-between;font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;color:var(--muted)}
.sm-ds-vals{display:flex;align-items:center;gap:7px;font-size:12px;font-weight:700}
.sm-bar-wrap{flex:1;display:flex;height:5px;border-radius:3px;overflow:hidden;background:rgba(255,255,255,.06)}
.sm-bar-home{height:100%;background:var(--blue)}
.sm-bar-away{height:100%;background:var(--orange)}
.sm-xg-hi{color:var(--orange);font-weight:700}
.sm-press-hi{color:var(--blue);font-weight:700}
.sm-signal-pill{display:inline-block;font-size:9px;font-weight:700;padding:1px 5px;border-radius:8px;background:rgba(248,81,73,.15);color:var(--red);border:1px solid rgba(248,81,73,.3);margin:1px}
/* SM inner tabs */
.sm-inner-tabs{display:flex;gap:4px;margin-bottom:14px;border-bottom:1px solid var(--border);padding-bottom:0}
.sm-inner-tab{background:none;border:none;border-bottom:2px solid transparent;color:var(--muted);font-size:11px;font-weight:600;padding:6px 12px;cursor:pointer;transition:color .15s,border-color .15s;margin-bottom:-1px}
.sm-inner-tab:hover{color:var(--text)}
.sm-inner-tab.active{color:var(--blue);border-bottom-color:var(--blue)}
/* Goal snapshots */
.sm-goal-group{background:var(--surface);border:1px solid var(--border);border-radius:8px;margin-bottom:10px;overflow:hidden}
.sm-goal-group-hdr{display:flex;align-items:center;gap:10px;padding:9px 14px;border-bottom:1px solid var(--border);background:rgba(255,255,255,.02)}
.sm-goal-group-teams{font-size:12px;font-weight:700;flex:1}
.sm-goal-group-score{font-size:14px;font-weight:800;color:var(--text);margin:0 4px}
.sm-goal-snap-row{display:grid;grid-template-columns:36px 90px 60px 110px 110px auto;align-items:center;gap:8px;padding:7px 14px;border-bottom:1px solid rgba(255,255,255,.04);font-size:11px}
.sm-goal-snap-row:last-child{border-bottom:none}
.sm-goal-snap-row:hover{background:rgba(255,255,255,.03)}
.sm-goal-min{font-size:12px;font-weight:700;color:var(--yellow);text-align:center}
.sm-goal-scorer{font-weight:600}
.sm-goal-scorer.home{color:var(--blue)}
.sm-goal-scorer.away{color:var(--orange)}
.sm-goal-newscore{font-size:12px;font-weight:800;text-align:center;color:var(--text)}
.sm-goal-stat{display:flex;flex-direction:column;gap:2px}
.sm-goal-stat-lbl{font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;color:var(--muted)}
.sm-goal-stat-val{font-size:11px;font-weight:700}
.sm-goal-atm{display:inline-block;font-size:9px;font-weight:700;padding:2px 6px;border-radius:8px;background:rgba(248,81,73,.15);color:var(--red);border:1px solid rgba(248,81,73,.3)}
.sm-goal-wtm{display:inline-block;font-size:9px;font-weight:700;padding:2px 6px;border-radius:8px;background:rgba(63,185,80,.1);color:#3fb950;border:1px solid rgba(63,185,80,.3)}
.sm-goal-snap-hdr{display:grid;grid-template-columns:36px 90px 60px 110px 110px auto;gap:8px;padding:5px 14px;font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;color:var(--muted);border-bottom:1px solid var(--border);background:rgba(0,0,0,.15)}
/* Football AI tab */
.fb-ai-layout{display:flex;flex:1;overflow:hidden;min-height:0}
.fb-ai-sidebar{width:230px;border-right:1px solid var(--border);background:var(--surface2);display:flex;flex-direction:column;flex-shrink:0}
.fb-ai-sidebar-hdr{padding:11px 13px;border-bottom:1px solid var(--border);font-size:12px;font-weight:700;display:flex;align-items:center;justify-content:space-between}
.fb-ai-history-list{flex:1;overflow-y:auto;padding:6px}
.fb-ai-hist-item{padding:8px 10px;border-radius:7px;cursor:pointer;border:1px solid transparent;margin-bottom:3px;transition:background .12s}
.fb-ai-hist-item:hover{background:var(--surface);border-color:var(--border)}
.fb-ai-hist-item.active{background:rgba(88,166,255,.08);border-color:rgba(88,166,255,.3)}
.fb-ai-hist-when{font-size:11px;font-weight:700;color:var(--text);margin-bottom:2px}
.fb-ai-hist-meta{font-size:10px;color:var(--muted)}
.fb-ai-main{flex:1;overflow-y:auto;padding:18px 22px}
.fb-ai-snap{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:14px}
.fb-ai-snap-cell{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:8px 14px;text-align:center;flex:1;min-width:80px}
.fb-ai-snap-val{font-size:17px;font-weight:800;margin-bottom:1px}
.fb-ai-snap-lbl{font-size:9px;color:var(--muted);text-transform:uppercase;letter-spacing:.4px}
.fb-ai-placeholder{display:flex;flex-direction:column;align-items:center;justify-content:center;height:280px;color:var(--muted);gap:10px}
.fb-ai-section{margin-bottom:18px}
.fb-ai-section h2{font-size:14px;font-weight:700;margin-bottom:8px;padding-bottom:6px;border-bottom:1px solid var(--border)}
.fb-ai-section p,.fb-ai-section li{font-size:13px;color:var(--text);line-height:1.7}
.fb-ai-section ul,.fb-ai-section ol{padding-left:18px;margin-top:4px}
.fb-ai-verdict{display:inline-flex;align-items:center;gap:3px;font-size:11px;font-weight:700;padding:1px 7px;border-radius:8px;margin-left:6px}
.verdict-keep{background:rgba(63,185,80,.15);color:var(--green);border:1px solid rgba(63,185,80,.3)}
.verdict-tune{background:rgba(227,179,65,.15);color:var(--yellow);border:1px solid rgba(227,179,65,.3)}
.verdict-drop{background:rgba(248,81,73,.15);color:var(--red);border:1px solid rgba(248,81,73,.3)}
.fb-ai-token-bar{margin-top:10px;padding:8px 12px;background:var(--surface);border:1px solid var(--border);border-radius:6px;font-size:10px;color:var(--muted);display:flex;gap:16px;flex-wrap:wrap}
</style>
</head>
<body>

<div class="hdr">
  <div class="hdr-top">
    <h1>⚽ <span>Football</span> Telegram Bot</h1>
    <div class="tabs">
      <button class="tab active" onclick="showTab('bets')">Bets</button>
      <button class="tab" onclick="showTab('analytics')">Analytics</button>
      <button class="tab" onclick="showTab('exceptions')">Exceptions</button>
      <button class="tab" onclick="showTab('sportmonks')">⚡ SportMonks</button>
      <button class="tab" onclick="showTab('football-ai')">🤖 AI Analysis</button>
    </div>
    <div class="hdr-r">
      <div class="live-dot" title="Live updates active"></div>
      <span class="upd" id="upd-txt">Connecting…</span>
      <button class="bell" id="bell" onclick="toggleNotifs()" title="Enable notifications">🔔</button>
      <button class="btn hi" id="import-btn" onclick="importCBB()">⬇ Import CBB</button>
      <button class="btn" onclick="reload()">↻</button>
    </div>
  </div>
</div>

<div class="toast-wrap" id="toasts"></div>

<!-- BETS VIEW -->
<div class="view" id="view-bets">
  <div class="left">
    <div class="filters">
      <input type="text" id="q" placeholder="Search match, market or strategy…" oninput="render()">
      <div class="filter-row">
        <select id="f-outcome" onchange="render()">
          <option value="">All outcomes</option>
          <option value="won">Won ✓</option>
          <option value="lost">Lost ✗</option>
          <option value="pending">Pending</option>
        </select>
        <select id="f-strat" onchange="render()"><option value="">All strategies</option></select>
      </div>
      <div class="filter-row">
        <select id="f-market" onchange="render()"><option value="">All markets</option></select>
        <select id="f-type" onchange="render()">
          <option value="">All types</option>
          <option value="live">Live logged</option>
          <option value="hist">CBB imported</option>
        </select>
      </div>
    </div>
    <div class="bet-list" id="list"></div>
  </div>
  <div class="right" id="detail"></div>
</div>

<!-- ANALYTICS VIEW -->
<div class="view hidden" id="view-analytics">
  <div class="analytics-wrap">
    <div class="a-main" id="a-main">
      <div class="a-mkt-bar">
        <button class="mf-btn active" data-mkt="" onclick="setAnalyticsMkt('')">All Markets</button>
        <button class="mf-btn" data-mkt="0.5" onclick="setAnalyticsMkt('0.5')">O/U 0.5</button>
        <button class="mf-btn" data-mkt="1.5" onclick="setAnalyticsMkt('1.5')">O/U 1.5</button>
        <button class="mf-btn" data-mkt="2.5" onclick="setAnalyticsMkt('2.5')">O/U 2.5</button>
      </div>
      <div class="sum-grid" id="a-summary"></div>
      <div class="a-grid" id="a-charts"></div>
    </div>
    <div class="a-sidebar hidden" id="a-sidebar">
      <div class="a-sb-hdr">
        <span>Manage Charts</span>
        <button class="btn" onclick="toggleSidebar()" style="padding:2px 8px;font-size:11px">✕</button>
      </div>
      <div class="a-sb-body" id="chart-toggles"></div>
    </div>
  </div>
</div>

<!-- SPORTMONKS VIEW -->
<div class="view hidden" id="view-sportmonks" style="flex-direction:column;overflow-y:auto;padding:16px 20px">

  <!-- Status bar -->
  <div class="sm-status-bar" id="sm-status-bar">
    <div class="sm-status-item">
      <span class="sm-status-dot" id="sm-dot"></span>
      <span id="sm-status-txt" style="font-size:12px;color:var(--muted)">Loading�</span>
    </div>
    <div class="sm-status-item">
      <span style="font-size:11px;color:var(--muted)">Last poll:</span>
      <span id="sm-last-poll" style="font-size:11px;color:var(--text);margin-left:4px">�</span>
    </div>
    <div class="sm-status-item">
      <span id="sm-fixture-count" style="font-size:11px;color:var(--text)">�</span>
      <span style="font-size:11px;color:var(--muted);margin-left:4px">live fixtures</span>
    </div>
    <div style="margin-left:auto;display:flex;gap:6px">
      <button class="btn" onclick="loadSmLive()">↻ Refresh</button>
    </div>
  </div>

  <!-- No API key notice -->
  <div id="sm-no-key" style="display:none;text-align:center;padding:36px 20px">
    <div style="font-size:32px;margin-bottom:10px">🔑</div>
    <div style="font-size:14px;font-weight:700;margin-bottom:6px">SportMonks API key not configured</div>
    <div style="font-size:12px;color:var(--muted);max-width:380px;margin:0 auto;line-height:1.6">
      Add <code style="background:var(--surface2);padding:1px 5px;border-radius:4px">SPORTMONKS_API_KEY=your_key</code>
      to <code style="background:var(--surface2);padding:1px 5px;border-radius:4px">/home/bots/telegram-listener/.env</code>
      then run <code style="background:var(--surface2);padding:1px 5px;border-radius:4px">pm2 restart telegram-listener --update-env</code>
    </div>
  </div>

  <!-- Inner sub-tabs -->
  <div class="sm-inner-tabs">
    <button class="sm-inner-tab active" id="sm-itab-live" onclick="smShowInnerTab('live')">Live Fixtures</button>
    <button class="sm-inner-tab" id="sm-itab-goals" onclick="smShowInnerTab('goals')">⚽ Goal Snapshots <span id="sm-goal-count-badge" style="font-size:10px;font-weight:400;color:var(--muted)"></span></button>
  </div>

  <!-- PANEL: Live Fixtures -->
  <div id="sm-panel-live">
    <div id="sm-fixtures-wrap">
      <div style="font-size:12px;font-weight:700;margin-bottom:10px;color:var(--text)">Live Fixtures <span id="sm-fixtures-sub" style="font-weight:400;color:var(--muted)"></span></div>
      <div id="sm-fixture-cards"></div>
    </div>

    <!-- Signals log -->
    <div style="margin-top:18px">
      <div style="font-size:12px;font-weight:700;margin-bottom:8px;color:var(--text)">Signal Log <span id="sm-signals-count" style="font-weight:400;color:var(--muted)"></span></div>
      <div id="sm-signals-empty" style="display:none;font-size:12px;color:var(--muted);padding:8px 0">No signals fired yet this session.</div>
      <div style="overflow-x:auto">
        <table class="sm-tbl" id="sm-signals-tbl" style="display:none">
          <thead>
            <tr>
              <th>Time</th>
              <th>Match</th>
              <th>Min</th>
              <th>Score</th>
              <th>Strategy</th>
              <th>xG Total</th>
              <th>xG Vel</th>
              <th>Danger Δ</th>
            </tr>
          </thead>
          <tbody id="sm-signals-tbody"></tbody>
        </table>
      </div>
    </div>

    <!-- Strategy reference card -->
    <div class="sm-strat-ref" style="margin-top:18px">
      <div style="font-size:12px;font-weight:700;margin-bottom:10px;color:var(--text)">Active Strategies (thresholds)</div>
      <div id="sm-strat-cards"></div>
    </div>
  </div>

  <!-- PANEL: Goal Snapshots -->
  <div id="sm-panel-goals" style="display:none">
    <div id="sm-goal-snaps-wrap">
      <div style="font-size:12px;color:var(--muted);padding:30px;text-align:center" id="sm-goal-snaps-empty">No goal snapshots yet � they are captured automatically when a goal is detected during polling.</div>
    </div>
  </div>

</div>

<!-- FOOTBALL AI VIEW -->
<div class="view hidden" id="view-football-ai" style="flex-direction:column;overflow:hidden">
  <div class="fb-ai-layout">
    <!-- Sidebar: run history -->
    <div class="fb-ai-sidebar">
      <div class="fb-ai-sidebar-hdr">
        <span>Run History</span>
        <button class="btn" onclick="runFootballAi(true)" title="Force new run" style="padding:2px 8px;font-size:10px">+ New</button>
      </div>
      <div class="fb-ai-history-list" id="fb-ai-history-list">
        <div style="padding:20px;text-align:center;color:var(--muted);font-size:11px">Loading�</div>
      </div>
    </div>
    <!-- Main content -->
    <div class="fb-ai-main" id="fb-ai-main">
      <!-- Snapshot strip -->
      <div class="fb-ai-snap" id="fb-ai-snap" style="display:none">
        <div class="fb-ai-snap-cell"><div class="fb-ai-snap-val" id="fb-ai-snap-bets">�</div><div class="fb-ai-snap-lbl">Settled Bets</div></div>
        <div class="fb-ai-snap-cell"><div class="fb-ai-snap-val" id="fb-ai-snap-won" style="color:var(--green)">�</div><div class="fb-ai-snap-lbl">Won</div></div>
        <div class="fb-ai-snap-cell"><div class="fb-ai-snap-val" id="fb-ai-snap-lost" style="color:var(--red)">�</div><div class="fb-ai-snap-lbl">Lost</div></div>
        <div class="fb-ai-snap-cell"><div class="fb-ai-snap-val" id="fb-ai-snap-pl">�</div><div class="fb-ai-snap-lbl">P&amp;L (pts)</div></div>
      </div>
      <!-- Placeholder -->
      <div class="fb-ai-placeholder" id="fb-ai-placeholder">
        <div style="font-size:36px">🤖</div>
        <div style="font-size:14px;font-weight:700">Football AI Analysis</div>
        <div style="font-size:12px;color:var(--muted);text-align:center;max-width:340px;line-height:1.6">Analyses your betting performance using Claude AI � strategy P&amp;L, market breakdowns, timing patterns, and SportMonks signal correlation.</div>
        <button class="btn hi" onclick="runFootballAi(true)" id="fb-ai-run-btn" style="margin-top:6px;padding:8px 18px;font-size:13px">Run Analysis</button>
      </div>
      <!-- Analysis sections rendered here -->
      <div id="fb-ai-sections" style="display:none"></div>
      <!-- Token usage footer -->
      <div class="fb-ai-token-bar" id="fb-ai-tokens" style="display:none"></div>
    </div>
  </div>
</div>

<!-- EXCEPTIONS VIEW -->
<div class="view hidden" id="view-exceptions" style="flex-direction:column;overflow-y:auto">
  <div style="padding:16px 20px 0">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px">
      <div style="font-size:13px;font-weight:700">Exception Report <span id="exc-count" style="color:var(--muted);font-weight:400;font-size:12px"></span></div>
      <div style="display:flex;gap:8px">
        <select id="exc-source" onchange="renderExceptions()" style="width:auto"><option value="">All sources</option><option value="bfbm">BFBM</option><option value="inplayguru">InPlayGuru</option></select>
        <select id="exc-reason" onchange="renderExceptions()" style="width:auto"><option value="">All reasons</option></select>
        <button class="btn" onclick="loadExceptions()">↻ Refresh</button>
      </div>
    </div>
    <div id="exc-list"></div>
  </div>
</div>

<script>
// ─── State ────────────────────────────────────────────────────────────────────
let allBets = [], selectedId = null, oddsChart = null, aCharts = {};
let lastReload = null, currentTab = 'bets', notifsEnabled = false, sseConnected = false;
let analyticsMarket = '', chartBets = [];

// ─── Chart library definition ─────────────────────────────────────────────────
const CHART_LIB = [
  { id:'stratPerf',      label:'Strategy Performance',       desc:'Win/loss/pending per strategy',             tall:true,  fn:'drawStratChart'        },
  { id:'cumPL',          label:'Cumulative P&L',             desc:'Running total of points over time',          tall:false, fn:'drawPLChart'            },
  { id:'cumPLByMarket',  label:'P&L by Market (all)',        desc:'Separate cumulative lines per market',       tall:false, fn:'drawCumPLByMarket'      },
  { id:'volume',     label:'Bets Per Day',                   desc:'Daily bet volume stacked by outcome',            tall:false, fn:'drawVolChart'      },
  { id:'mktOverview', label:'Market Overview',               desc:'Strike rate, avg odds & yield per market',       tall:false, fn:'drawMktOverview'   },
  { id:'oddsDist',   label:'Odds Distribution',              desc:'Implied probability vs actual strike rate',      tall:false, fn:'drawOddsDist'      },
  { id:'stratPL',    label:'P&L by Strategy',                desc:'Total points profit/loss per strategy',          tall:false, fn:'drawStratPL'       },
  { id:'stratOdds',  label:'Avg Odds by Strategy',           desc:'Average placement odds per strategy',            tall:false, fn:'drawStratOdds'     },
  { id:'timerDist',  label:'Bets by Match Minute',           desc:'When in the match bets are placed',              tall:false, fn:'drawTimerDist'     },
  { id:'hourDist',   label:'Bets by Hour of Day',            desc:'What time of day bets land',                    tall:false, fn:'drawHourDist'      },
  { id:'dowDist',    label:'Bets by Day of Week',            desc:'Which days have most bets',                      tall:false, fn:'drawDOWDist'       },
  { id:'monthlyPL',  label:'Monthly P&L',                    desc:'P&L grouped by calendar month',                 tall:false, fn:'drawMonthlyPL'     },
  { id:'scoreDist',  label:'Goals at Signal',                desc:'How many goals when bets were placed',           tall:false, fn:'drawScoreDist'     },
];
const DEFAULT_CHARTS = ['stratPerf','cumPL','cumPLByMarket','volume','mktOverview','oddsDist','timerDist','scoreDist'];

function loadChartPrefs() {
  try { const p = JSON.parse(localStorage.getItem('chartPrefs')); if(Array.isArray(p)) return p; } catch(_){}
  return DEFAULT_CHARTS;
}
function saveChartPrefs(prefs) { localStorage.setItem('chartPrefs', JSON.stringify(prefs)); }
let activeCharts = loadChartPrefs();

// ─── Outcome config ───────────────────────────────────────────────────────────
const OC = { won:{label:'✓ Won',cls:'badge-won',card:'green'}, lost:{label:'✗ Lost',cls:'badge-lost',card:'red'}, void:{label:'— Void',cls:'badge-void',card:'yellow'}, pending:{label:'… Pending',cls:'badge-pending',card:'muted'} };
const oc = b => OC[b.result] || OC.pending;

// ─── Notifications ────────────────────────────────────────────────────────────
function toggleNotifs() {
  if (!('Notification' in window)) return;
  if (notifsEnabled) { notifsEnabled=false; document.getElementById('bell').classList.remove('on'); return; }
  Notification.requestPermission().then(p => { if(p==='granted'){notifsEnabled=true;document.getElementById('bell').classList.add('on'); new Notification('Bet Dashboard',{body:'Notifications enabled ✓'}); }});
}
function fireBetNotification(bet) {
  showToast(bet);
  if (notifsEnabled && Notification.permission==='granted') {
    const name=bet.match||bet.marketName||bet.marketId;
    const body=`Over ${bet.overUnderValue||'?'} @ ${bet.overOdds?.toFixed(2)||'?'} | ${bet.strategy}${bet.isCompanion?' [Companion]':''}`;
    try { new Notification(bet.success?`✅ Bet placed — ${name}`:`❌ Bet failed — ${name}`,{body,tag:bet.id,renotify:true}); } catch(_){}
  }
}
function showToast(bet) {
  const wrap=document.getElementById('toasts');
  const name=bet.match||bet.marketName||bet.marketId||'Unknown';
  const el=document.createElement('div');
  el.className=`toast ${bet.success?'placed':'failed'}`;
  el.innerHTML=`<div class="toast-title">${bet.success?'✅':'❌'} ${esc(bet.success?'Bet placed':'Bet failed')}</div>
    <div class="toast-body"><strong>${esc(name)}</strong><br>
    Over/Under ${bet.overUnderValue||'?'} ${bet.overOdds?`@ <strong style="color:var(--orange)">${bet.overOdds.toFixed(2)}</strong>`:''} &nbsp;|&nbsp; <span style="color:var(--blue)">${esc(bet.strategy||'')}</span>${bet.isCompanion?'<br><span style="color:var(--purple)">🔗 Companion</span>':''}</div>
    <button class="toast-close" onclick="this.parentElement.remove()">✕</button>`;
  wrap.appendChild(el);
  setTimeout(()=>el.style.transition='opacity .4s',4500);
  setTimeout(()=>{el.style.opacity='0';setTimeout(()=>el.remove(),400);},5000);
}

// ─── SSE ──────────────────────────────────────────────────────────────────────
function connectSSE() {
  const es=new EventSource('/football/api/events');
  es.onopen=()=>{sseConnected=true;document.getElementById('upd-txt').textContent='Live';document.querySelector('.live-dot').style.background='var(--green)';};
  es.onmessage=(e)=>{try{const nb=JSON.parse(e.data);nb.forEach(b=>{fireBetNotification(b);allBets.unshift(b);});updateStats();render();if(currentTab==='analytics')renderAnalytics();}catch(_){}};
  es.onerror=()=>{sseConnected=false;document.querySelector('.live-dot').style.background='var(--yellow)';document.getElementById('upd-txt').textContent='Reconnecting…';es.close();setTimeout(connectSSE,5000);};
}

// ─── Clock ────────────────────────────────────────────────────────────────────
setInterval(()=>{if(!lastReload||sseConnected)return;const s=Math.round((Date.now()-lastReload)/1000);document.getElementById('upd-txt').textContent=s<5?'Just updated':`Updated ${s}s ago`;},1000);

// ─── Data ─────────────────────────────────────────────────────────────────────
async function reload() {
  try{const r=await fetch('/football/api/bets');allBets=await r.json();lastReload=new Date();if(!sseConnected)document.getElementById('upd-txt').textContent='Updated just now';}catch(e){return;}
  updateStats();populateFilters();render();
  if(currentTab==='analytics')renderAnalytics();
  if(currentTab==='bets')renderBpContent();
}

function updateStats() { /* stats live in the analytics summary now */ }

function populateFilters() {
  const strats=[...new Set(allBets.map(b=>b.strategy).filter(Boolean))].sort();
  const mkts=[...new Set(allBets.map(b=>b.overUnderValue).filter(Boolean))].sort((a,b)=>parseFloat(a)-parseFloat(b));
  const fs=document.getElementById('f-strat'),cur=fs.value;
  fs.innerHTML='<option value="">All strategies</option>'+strats.map(s=>`<option${s===cur?' selected':''}>${s}</option>`).join('');
  const fm=document.getElementById('f-market'),curm=fm.value;
  fm.innerHTML='<option value="">All markets</option>'+mkts.map(v=>`<option value="${v}"${v===curm?' selected':''}>Over/Under ${v}</option>`).join('');
}

function filtered() {
  const q=document.getElementById('q').value.toLowerCase(),oc2=document.getElementById('f-outcome').value,st=document.getElementById('f-strat').value,mk=document.getElementById('f-market').value,tp=document.getElementById('f-type').value;
  return allBets.filter(b=>{
    const nm=(b.match||b.marketName||'').toLowerCase();
    if(q&&!nm.includes(q)&&!(b.strategy||'').toLowerCase().includes(q))return false;
    if(oc2&&b.result!==oc2)return false;if(st&&b.strategy!==st)return false;if(mk&&b.overUnderValue!==mk)return false;
    if(tp==='live'&&b.isHistorical)return false;if(tp==='hist'&&!b.isHistorical)return false;return true;
  });
}

// ─── Tab ──────────────────────────────────────────────────────────────────────
function showTab(tab) {
  currentTab=tab;
  const tabNames=['bets','analytics','exceptions','sportmonks','football-ai'];
  document.querySelectorAll('.tab').forEach((t,i)=>t.classList.toggle('active',tabNames[i]===tab));
  document.getElementById('view-bets').classList.toggle('hidden',tab!=='bets');
  document.getElementById('view-analytics').classList.toggle('hidden',tab!=='analytics');
  document.getElementById('view-exceptions').classList.toggle('hidden',tab!=='exceptions');
  document.getElementById('view-sportmonks').classList.toggle('hidden',tab!=='sportmonks');
  document.getElementById('view-football-ai').classList.toggle('hidden',tab!=='football-ai');
  if(tab==='analytics'){renderSidebar();renderAnalytics();}
  if(tab==='exceptions')loadExceptions();
  if(tab==='bets')renderBetsPanel();
  if(tab==='sportmonks')loadSmLive();
  if(tab==='football-ai')loadFootballAiHistory();
}

// ─── Bet list ─────────────────────────────────────────────────────────────────
function render() {
  const bets=filtered(),el=document.getElementById('list');
  if(!bets.length){el.innerHTML='<div class="no-bets">No bets match filters</div>';}
  else{
    el.innerHTML=bets.map(b=>{
      const d=new Date(b.placedAt),ds=d.toLocaleDateString('en-GB',{day:'numeric',month:'short'}),ts=d.toLocaleTimeString('en-GB',{hour:'2-digit',minute:'2-digit'});
      const o=oc(b),nm=b.match||b.marketName||b.marketId||'Unknown';
      const ocBadge=`<span class="badge ${o.cls}">${o.label}</span>`;
      const typBadge=b.isHistorical?`<span class="badge badge-pending">CBB</span>`:b.isCompanion?`<span class="badge badge-comp">🔗</span>`:b.success?`<span class="badge badge-ok">✓</span>`:`<span class="badge badge-fail">✗</span>`;
      const outcls=b.result==='won'?' ow':b.result==='lost'?' ol':'';
      return `<div class="bet-card${b.id===selectedId?' active':''}${outcls}" data-id="${esc(b.id)}">
        <div class="bc-top"><div class="bc-match">${esc(trunc(nm,34))}</div><div class="badges">${ocBadge}${typBadge}<button class="del-fb-btn" onclick="event.stopPropagation();deleteFootballBet('${esc(b.id)}')" title="Delete">✕</button></div></div>
        <div class="bc-meta"><span class="bc-time">${ds} ${ts}</span><span class="strat-pill">${esc(b.strategy||'?')}</span><span class="bc-market">O/U ${b.overUnderValue||'?'}</span>
          ${b.avePoints!=null?`<span style="font-size:10px;font-weight:600;color:${b.avePoints>=0?'var(--green)':'var(--red)'}">${b.avePoints>=0?'+':''}${b.avePoints.toFixed(2)}pts</span>`:''}
          <span class="bc-odds">${b.overOdds!=null?b.overOdds.toFixed(2):'—'}</span></div></div>`;
    }).join('');
    el.querySelectorAll('.bet-card').forEach(c=>c.addEventListener('click',()=>selectBet(c.dataset.id)));
  }
  if(currentTab==='bets'&&!document.getElementById('bp-sys-tabs')) renderBetsPanel();
}

function selectBet(id){selectedId=id;render();}

// ─── Bets page right panel — A20/B20/C20 summary ─────────────────────────────
const BP_SYSTEMS=[{id:'SystemA20',label:'A20',color:'#58a6ff'},{id:'SystemB20',label:'B20',color:'#3fb950'},{id:'SystemC20',label:'C20',color:'#f0883e'}];
let bpCharts={}, bpSystem='';

function setBpSystem(sys){
  bpSystem=sys;
  document.querySelectorAll('#bp-sys-tabs .mf-btn').forEach(b=>b.classList.toggle('active',b.dataset.sys===sys));
  renderBpContent();
}

function sysBets(sys){
  const ids=sys?[sys]:BP_SYSTEMS.map(s=>s.id);
  return allBets.filter(b=>ids.includes(b.strategy));
}

function renderBpContent(){
  const bets=sysBets(bpSystem);
  renderBpStats(bets);
  renderBpCharts(bets);
  renderBpBetList(bets);
}

function renderBpStats(bets){
  const wrap=document.getElementById('bp-stats-wrap');if(!wrap)return;
  if(!bpSystem){
    // Side-by-side summary for each system
    wrap.innerHTML=`<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:12px">
      ${BP_SYSTEMS.map(({id,label,color})=>{
        const sb=allBets.filter(b=>b.strategy===id);
        const won=sb.filter(b=>b.result==='won').length,lost=sb.filter(b=>b.result==='lost').length,s=won+lost;
        const pl=sb.reduce((a,b)=>a+(b.avePoints??0),0);
        const yield_=s>0?pl/s*100:null;
        const oddsArr=sb.filter(b=>b.overOdds!=null).map(b=>b.overOdds);
        const avg=oddsArr.length?oddsArr.reduce((a,b)=>a+b,0)/oddsArr.length:null;
        return`<div style="background:var(--surface);border:1px solid var(--border);border-top:3px solid ${color};border-radius:8px;padding:12px">
          <div style="font-size:13px;font-weight:700;color:${color};margin-bottom:10px">System ${label}</div>
          ${[['Bets',sb.length,'var(--text)'],['Won',won,'var(--green)'],['Lost',lost,'var(--red)'],
             ['SR',s>0?(won/s*100).toFixed(1)+'%':'—',won>=lost?'var(--green)':'var(--red)'],
             ['Avg Odds',avg!=null?avg.toFixed(2):'—','var(--orange)'],
             ['Yield',yield_!=null?(yield_>=0?'+':'')+yield_.toFixed(1)+'%':'—',yield_!=null?(yield_>=0?'var(--green)':'var(--red)'):'var(--muted)'],
             ['P&L',s>0?(pl>=0?'+':'')+pl.toFixed(2):'—',pl>=0?'var(--green)':'var(--red)'],
            ].map(([l,v,c])=>`<div style="display:flex;justify-content:space-between;padding:4px 0;border-bottom:1px solid rgba(48,54,61,.3)">
              <span style="font-size:11px;color:var(--muted)">${l}</span>
              <span style="font-size:11px;font-weight:700;color:${c}">${v}</span>
            </div>`).join('')}
        </div>`;
      }).join('')}
    </div>`;
  } else {
    const won=bets.filter(b=>b.result==='won').length,lost=bets.filter(b=>b.result==='lost').length,s=won+lost;
    const pl=bets.reduce((a,b)=>a+(b.avePoints??0),0);
    const oddsArr=bets.filter(b=>b.overOdds!=null).map(b=>b.overOdds);
    const avg=oddsArr.length?oddsArr.reduce((a,b)=>a+b,0)/oddsArr.length:null;
    const yield_=s>0?pl/s*100:null;
    wrap.innerHTML=`<div class="bp-stats" style="margin-bottom:12px">
      ${[['Total',bets.length,'var(--blue)'],['Won',won,'var(--green)'],['Lost',lost,'var(--red)'],
         ['Strike Rate',s>0?(won/s*100).toFixed(1)+'%':'—',won>=lost?'var(--green)':'var(--red)'],
         ['Avg Odds',avg!=null?avg.toFixed(2):'—','var(--orange)'],
         ['Yield',yield_!=null?(yield_>=0?'+':'')+yield_.toFixed(1)+'%':'—',yield_!=null?(yield_>=0?'var(--green)':'var(--red)'):'var(--muted)'],
         ['P&L',s>0?(pl>=0?'+':'')+pl.toFixed(2)+'pts':'—',pl>=0?'var(--green)':'var(--red)'],
        ].map(([l,v,c])=>`<div class="bp-stat"><div class="bp-stat-val" style="color:${c}">${v}</div><div class="bp-stat-lbl">${l}</div></div>`).join('')}
    </div>`;
  }
}

function renderBpCharts(bets){
  Object.values(bpCharts).forEach(c=>c.destroy());bpCharts={};
  const co={responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{backgroundColor:'#1c2128',borderColor:'#30363d',borderWidth:1,bodyColor:'#e6edf3',padding:8}},scales:{x:{grid:{color:'rgba(48,54,61,.4)'},ticks:{color:'#8b949e',font:{size:10},maxTicksLimit:12}},y:{grid:{color:'rgba(48,54,61,.4)'},ticks:{color:'#8b949e',font:{size:10}}}}};

  if(!bpSystem){
    // Multi-line cumPL: one line per system
    const allDates=new Set();const mktDaily={};
    for(const{id}of BP_SYSTEMS){
      const pts=allBets.filter(b=>b.strategy===id&&b.avePoints!=null);
      if(!pts.length)continue;
      mktDaily[id]={};
      for(const b of pts){const d=b.placedAt.split('T')[0];mktDaily[id][d]=(mktDaily[id][d]||0)+b.avePoints;allDates.add(d);}
    }
    const days=[...allDates].sort();
    const datasets=BP_SYSTEMS.filter(s=>mktDaily[s.id]).map(({id,label,color})=>{
      const lastDay=Object.keys(mktDaily[id]).sort().pop();
      let cum=0;const data=[];
      for(const d of days){if(mktDaily[id][d]!=null)cum=parseFloat((cum+mktDaily[id][d]).toFixed(2));data.push({x:d,y:cum});if(d===lastDay)break;}
      return{label:`System ${label}`,data,borderColor:color,backgroundColor:'transparent',tension:.3,pointRadius:2,borderWidth:2,fill:false};
    });
    const ctx=document.getElementById('bp-cumpl');
    if(ctx&&datasets.length)bpCharts.cumpl=new Chart(ctx,{type:'line',data:{datasets},options:{...co,plugins:{...co.plugins,legend:{display:true,labels:{color:'#8b949e',boxWidth:10,font:{size:10}}}},scales:{x:{type:'category',grid:co.scales.x.grid,ticks:{...co.scales.x.ticks}},y:co.scales.y}}});
  } else {
    const pts=bets.filter(b=>b.avePoints!=null).sort((a,b)=>new Date(a.placedAt)-new Date(b.placedAt));
    if(pts.length>=2){
      const daily={};for(const b of pts){const d=b.placedAt.split('T')[0];daily[d]=(daily[d]||0)+b.avePoints;}
      const days=Object.keys(daily).sort();let cum=0;
      const data=days.map(d=>{cum=parseFloat((cum+daily[d]).toFixed(2));return{x:d,y:cum};});
      const col=BP_SYSTEMS.find(s=>s.id===bpSystem)?.color||'#58a6ff';
      const ctx=document.getElementById('bp-cumpl');
      if(ctx)bpCharts.cumpl=new Chart(ctx,{type:'line',data:{datasets:[{data,borderColor:col,backgroundColor:col.replace('rgb','rgba').replace(')',', .08)')||'rgba(88,166,255,.08)',tension:.3,pointRadius:2,borderWidth:2,fill:true}]},
        options:{...co,plugins:{...co.plugins,tooltip:{...co.plugins.tooltip,callbacks:{label:c=>`${c.parsed.y>=0?'+':''}${c.parsed.y.toFixed(2)} pts`}}},scales:{x:{type:'category',grid:co.scales.x.grid,ticks:{...co.scales.x.ticks}},y:co.scales.y}}});
    }
  }

  // Bets per day (always just Won/Lost bars)
  const dm={};for(const b of bets){if(!b.result||b.result==='pending')continue;const d=b.placedAt?.split('T')[0]||'?';if(!dm[d])dm[d]={w:0,l:0};if(b.result==='won')dm[d].w++;else dm[d].l++;}
  const days2=Object.keys(dm).sort().slice(-45);
  if(days2.length){
    const ctx2=document.getElementById('bp-bpd');
    if(ctx2)bpCharts.bpd=new Chart(ctx2,{type:'bar',data:{labels:days2,datasets:[{label:'Won',data:days2.map(d=>dm[d].w),backgroundColor:'rgba(63,185,80,.7)',borderRadius:2},{label:'Lost',data:days2.map(d=>dm[d].l),backgroundColor:'rgba(248,81,73,.7)',borderRadius:2}]},
      options:{...co,plugins:{...co.plugins,legend:{display:true,labels:{color:'#8b949e',boxWidth:8,font:{size:10}}}},scales:{x:{stacked:true,...co.scales.x},y:{stacked:true,...co.scales.y}}}});
  }
}

function renderBpBetList(bets){
  const wrap=document.getElementById('bp-table-wrap');if(!wrap)return;
  if(!bpSystem){wrap.innerHTML='<div class="no-bets" style="padding:20px;font-size:12px">Select a system tab to see individual bets</div>';return;}
  const shown=bets.slice(0,20);
  const won=bets.filter(b=>b.result==='won').length,lost=bets.filter(b=>b.result==='lost').length;
  const col=BP_SYSTEMS.find(s=>s.id===bpSystem)?.color||'var(--blue)';
  if(!shown.length){wrap.innerHTML='<div class="no-bets" style="padding:20px">No settled bets yet</div>';return;}
  wrap.innerHTML=`
    <div style="font-size:11px;color:var(--muted);padding:2px 0 8px;display:flex;gap:12px">
      <span>${bets.length} total</span>
      <span style="color:var(--green)">${won}W</span><span style="color:var(--red)">${lost}L</span>
      ${won+lost>0?`<span>SR: <strong style="color:${won>=lost?'var(--green)':'var(--red)'}">${(won/(won+lost)*100).toFixed(1)}%</strong></span>`:''}
      <span style="color:var(--muted)">Showing last ${shown.length}</span>
    </div>
    <div style="display:flex;flex-direction:column;gap:5px">
      ${shown.map(b=>{
        const o=oc(b);
        const d=new Date(b.placedAt);
        const borderCol=b.result==='won'?'var(--green)':b.result==='lost'?'var(--red)':'var(--border)';
        return`<div style="background:var(--surface);border:1px solid var(--border);border-left:3px solid ${borderCol};border-radius:7px;padding:9px 12px">
          <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:8px;margin-bottom:4px">
            <div style="font-size:12px;font-weight:600;line-height:1.3;flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${esc(b.match||b.marketId||'Unknown')}</div>
            <span class="badge ${o.cls}">${o.label}</span>
          </div>
          <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;font-size:11px;color:var(--muted)">
            <span>${d.toLocaleDateString('en-GB',{day:'numeric',month:'short'})} ${d.toLocaleTimeString('en-GB',{hour:'2-digit',minute:'2-digit'})}</span>
            <span style="color:var(--muted)">O/U ${b.overUnderValue||'?'}</span>
            <span style="color:var(--orange);font-weight:600">${b.overOdds!=null?b.overOdds.toFixed(2):'—'}</span>
            ${b.avePoints!=null?`<span style="font-weight:700;color:${b.avePoints>=0?'var(--green)':'var(--red)'}">${b.avePoints>=0?'+':''}${b.avePoints.toFixed(2)}pts</span>`:''}
          </div>
        </div>`;
      }).join('')}
    </div>`;
}

function renderBetsPanel(){
  const panel=document.getElementById('detail');
  panel.innerHTML=`
    <div class="a-mkt-bar" id="bp-sys-tabs" style="padding:0 0 10px">
      ${[{id:'',label:'All Systems'},...BP_SYSTEMS.map(s=>({id:s.id,label:`System ${s.label}`}))].map(s=>`<button class="mf-btn${bpSystem===s.id?' active':''}" data-sys="${s.id}" onclick="setBpSystem('${s.id}')">${s.label}</button>`).join('')}
    </div>
    <div id="bp-stats-wrap"></div>
    <div class="bp-charts-row">
      <div class="section"><div class="sec-title">Cumulative P&L</div><div class="chart-wrap"><canvas id="bp-cumpl"></canvas></div></div>
      <div class="section"><div class="sec-title">Bets Per Day</div><div class="chart-wrap"><canvas id="bp-bpd"></canvas></div></div>
    </div>
    <div id="bp-table-wrap"></div>`;
  renderBpContent();
}

// ─── Per-bet context analytics ────────────────────────────────────────────────
function betContextHTML(b) {
  const settled = r => r==='won'||r==='lost';
  // Strategy stats
  const sBets=allBets.filter(x=>x.strategy===b.strategy&&settled(x.result));
  const sWon=sBets.filter(x=>x.result==='won').length,sLost=sBets.length-sWon;
  const sWR=sBets.length>0?Math.round(sWon/sBets.length*100):null;
  const sAvgOdds=sBets.filter(x=>x.overOdds!=null).length>0?sBets.filter(x=>x.overOdds!=null).reduce((a,x)=>a+x.overOdds,0)/sBets.filter(x=>x.overOdds!=null).length:null;
  const sPL=sBets.reduce((a,x)=>a+(x.avePoints??0),0);

  // Market stats
  const mBets=allBets.filter(x=>x.overUnderValue===b.overUnderValue&&settled(x.result));
  const mWon=mBets.filter(x=>x.result==='won').length;
  const mWR=mBets.length>0?Math.round(mWon/mBets.length*100):null;

  // P&L contribution
  const totalPL=allBets.reduce((a,x)=>a+(x.avePoints??0),0);
  const contrib=b.avePoints!=null&&totalPL!==0?(b.avePoints/totalPL*100).toFixed(1):null;

  // Odds vs strategy average
  let oddsMarkerHTML='';
  if(b.overOdds!=null&&sAvgOdds!=null) {
    const allOdds=allBets.filter(x=>x.overOdds!=null).map(x=>x.overOdds);
    const minO=Math.min(...allOdds),maxO=Math.max(...allOdds);
    const range=maxO-minO||1;
    const betPct=Math.min(100,Math.max(0,(b.overOdds-minO)/range*100));
    const avgPct=Math.min(100,Math.max(0,(sAvgOdds-minO)/range*100));
    const diff=b.overOdds-sAvgOdds;
    const diffStr=(diff>=0?'+':'')+diff.toFixed(2);
    const diffCol=diff>=0?'var(--green)':'var(--red)';
    oddsMarkerHTML=`<div class="ctx-odds-row">
      <span style="color:var(--muted);font-size:11px;white-space:nowrap">Odds vs strategy avg</span>
      <div class="odds-marker"><div class="odds-marker-dot" style="left:${betPct}%;background:var(--orange)" title="This bet: ${b.overOdds.toFixed(2)}"></div>
        <div class="odds-marker-dot" style="left:${avgPct}%;background:var(--muted);width:8px;height:8px;top:-2px" title="Avg: ${sAvgOdds.toFixed(2)}"></div></div>
      <span style="font-size:11px;font-weight:700;color:${diffCol}">${diffStr}</span>
    </div>`;
  }

  if(!sBets.length&&!mBets.length) return '';

  return `<div class="section">
    <div class="sec-title">Bet Context</div>
    <div class="ctx-grid">
      ${sBets.length>0?`<div class="ctx-card">
        <div class="ctx-label">${esc(b.strategy||'Strategy')}</div>
        <div class="ctx-val" style="color:${sWR>=50?'var(--green)':'var(--red)'}">${sWR!=null?sWR+'%':'—'}</div>
        <div class="ctx-sub">${sWon}W ${sLost}L from ${sBets.length} settled${sPL!==0?` · ${sPL>=0?'+':''}${sPL.toFixed(1)}pts`:''}</div>
        ${sWR!=null?`<div class="bar-track"><div class="bar-fill" style="width:${sWR}%;background:${sWR>=50?'var(--green)':'var(--red)'}"></div></div>`:''}
      </div>`:''}
      ${mBets.length>0&&b.overUnderValue?`<div class="ctx-card">
        <div class="ctx-label">Over/Under ${b.overUnderValue}</div>
        <div class="ctx-val" style="color:${mWR>=50?'var(--green)':'var(--red)'}">${mWR!=null?mWR+'%':'—'}</div>
        <div class="ctx-sub">${mWon}W ${mBets.length-mWon}L from ${mBets.length} settled</div>
        ${mWR!=null?`<div class="bar-track"><div class="bar-fill" style="width:${mWR}%;background:${mWR>=50?'var(--green)':'var(--red)'}"></div></div>`:''}
      </div>`:''}
    </div>
    ${oddsMarkerHTML}
    ${contrib!=null?`<div style="font-size:11px;color:var(--muted);margin-top:8px;padding-top:8px;border-top:1px solid var(--border)">
      This bet contributed <strong style="color:${b.avePoints>=0?'var(--green)':'var(--red)'}">${b.avePoints>=0?'+':''}${b.avePoints?.toFixed(2)}pts</strong>
      (${contrib}% of total P&L of ${totalPL>=0?'+':''}${totalPL.toFixed(2)}pts)
    </div>`:''}
  </div>`;
}

// ─── Strategy overview (all bets including pending) ───────────────────────────
function strategyOverviewHTML(b) {
  const all=allBets.filter(x=>x.strategy===b.strategy);
  if(!all.length) return '';
  const settled=all.filter(x=>x.result==='won'||x.result==='lost');
  const won=settled.filter(x=>x.result==='won').length,lost=settled.length-won;
  const pending=all.filter(x=>x.result==='pending').length;
  const pl=settled.reduce((a,x)=>a+(x.avePoints??0),0);
  const oddsArr=all.filter(x=>x.overOdds!=null).map(x=>x.overOdds);
  const avgOdds=oddsArr.length?oddsArr.reduce((a,x)=>a+x,0)/oddsArr.length:null;
  const wr=settled.length>0?Math.round(won/settled.length*100):null;
  const yield_=settled.length>0?(pl/settled.length*100):null;
  const mkts=[...new Set(all.map(x=>x.overUnderValue).filter(Boolean))].sort((a,b)=>parseFloat(a)-parseFloat(b));
  return `<div class="section">
    <div class="sec-title">Strategy — ${esc(b.strategy||'—')}</div>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:6px;margin-bottom:10px">
      ${[['Total',all.length,'var(--blue)'],['Won',won||'—','var(--green)'],['Lost',lost||'—','var(--red)']].map(([l,v,c])=>
        `<div style="text-align:center;padding:7px 4px;background:var(--surface2);border-radius:6px;border:1px solid var(--border)">
          <div style="font-size:15px;font-weight:700;color:${c}">${v}</div>
          <div style="font-size:9px;color:var(--muted);text-transform:uppercase;margin-top:2px">${l}</div>
        </div>`).join('')}
    </div>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:6px">
      ${[['Strike Rate',wr!=null?wr+'%':'—',wr!=null?(wr>=50?'var(--green)':'var(--red)'):'var(--muted)'],
         ['Avg Odds',avgOdds!=null?avgOdds.toFixed(2):'—','var(--orange)'],
         ['Yield',yield_!=null?(yield_>=0?'+':'')+yield_.toFixed(1)+'%':'—',yield_!=null?(yield_>=0?'var(--green)':'var(--red)'):'var(--muted)'],
      ].map(([l,v,c])=>
        `<div style="text-align:center;padding:7px 4px;background:var(--surface2);border-radius:6px;border:1px solid var(--border)">
          <div style="font-size:15px;font-weight:700;color:${c}">${v}</div>
          <div style="font-size:9px;color:var(--muted);text-transform:uppercase;margin-top:2px">${l}</div>
        </div>`).join('')}
    </div>
    ${pl!==0||mkts.length?`<div style="font-size:11px;color:var(--muted);margin-top:8px;padding-top:8px;border-top:1px solid var(--border);display:flex;gap:12px;flex-wrap:wrap">
      ${settled.length?`<span>P&L: <strong style="color:${pl>=0?'var(--green)':'var(--red)'}">${pl>=0?'+':''}${pl.toFixed(2)}pts</strong></span>`:''}
      ${mkts.length?`<span>Markets: ${mkts.map(v=>`<span class="strat-pill">O/U ${v}</span>`).join(' ')}</span>`:''}
    </div>`:''}
  </div>`;
}

// ─── Same-market bets (other strategies on this match) ────────────────────────
function sameMarketHTML(b) {
  const related=allBets.filter(x=>x.marketId===b.marketId&&x.id!==b.id);
  if(!related.length) return '';
  const totalPL=related.reduce((a,x)=>a+(x.avePoints??0),0);
  return `<div class="section" style="margin-top:11px">
    <div class="sec-title">
      Same Match — ${related.length} other bet${related.length!==1?'s':''}
      ${totalPL!==0?`<span style="font-weight:600;color:${totalPL>=0?'var(--green)':'var(--red)'}">${totalPL>=0?'+':''}${totalPL.toFixed(2)}pts combined</span>`:''}
    </div>
    <table>
      <tr><th>Strategy</th><th>Type</th><th>Over</th><th>Under</th><th>P&L</th><th>Result</th></tr>
      ${related.map(x=>{const xo=oc(x);return`<tr>
        <td><span class="strat-pill">${esc(x.strategy||'—')}</span></td>
        <td style="color:var(--muted);font-size:11px">${x.isHistorical?'CBB':x.isCompanion?'🔗 Comp':x.success?'Live':'✗ Failed'}</td>
        <td style="color:var(--orange);font-weight:600">${x.overOdds!=null?x.overOdds.toFixed(2):'—'}</td>
        <td style="color:var(--blue)">${x.underOdds!=null?x.underOdds.toFixed(2):'—'}</td>
        <td style="color:${x.avePoints!=null?(x.avePoints>=0?'var(--green)':'var(--red)'):'var(--muted)'}">
          ${x.avePoints!=null?(x.avePoints>=0?'+':'')+x.avePoints.toFixed(2):'—'}</td>
        <td><span class="badge ${xo.cls}">${xo.label}</span></td>
      </tr>`}).join('')}
    </table>
  </div>`;
}

// ─── Live price snapshot fetch ─────────────────────────────────────────────────
async function fetchLiveSnapshot(betId) {
  try {
    const r=await fetch(`/football/api/bets/${encodeURIComponent(betId)}/live-snapshot`,{method:'POST'});
    const d=await r.json();
    if(d.ok&&!d.isDup) {
      const bet=allBets.find(x=>x.id===betId);
      if(bet) {
        bet.priceSnapshots=bet.priceSnapshots||[];
        bet.priceSnapshots.push(d.snapshot);
        const chart=document.getElementById('ochart');
        if(bet.priceSnapshots.length>=2) {
          if(!chart) { showDetail(bet); return; } // re-render if chart section was showing placeholder
          drawOddsChart(bet.priceSnapshots);
        }
        const cnt=document.getElementById('snap-count');
        if(cnt) cnt.textContent=`(${bet.priceSnapshots.length})`;
      }
    }
  } catch(_) {}
  const btn=document.getElementById('live-odds-btn');
  if(btn){btn.disabled=false;btn.textContent='↻ Live';}
}
function triggerLiveOdds(betId){
  const btn=document.getElementById('live-odds-btn');
  if(btn){btn.disabled=true;btn.textContent='⏳';}
  fetchLiveSnapshot(betId);
}

// ─── Detail panel ─────────────────────────────────────────────────────────────
function showDetail(b) {
  const panel=document.getElementById('detail');
  const d=new Date(b.placedAt),dateStr=d.toLocaleString('en-GB',{day:'numeric',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'});
  const score=b.goalsA!=null?`${b.goalsA}–${b.goalsB}`:null,final=b.finalGoalsA!=null?`${b.finalGoalsA}–${b.finalGoalsB}`:null;
  const o=oc(b),snaps=b.priceSnapshots||[];
  const cbbCls=b.isHistorical?'muted':b.isCompanion?'purple':b.success?'green':'red';
  const cbbTxt=b.isHistorical?'CBB Import':b.isCompanion?'🔗 Companion':b.success?'Placed ✓':'Failed ✗';

  // Stats strip cells — always show all 7, use — for missing
  const stripCells=[
    {lbl:'Outcome',  val:o.label,                             col:`var(--${o.card})`},
    {lbl:'CBB',      val:cbbTxt,                              col:`var(--${cbbCls})`},
    {lbl:'Over',     val:b.overOdds!=null?b.overOdds.toFixed(2):'—',  col:'var(--orange)'},
    {lbl:'Under',    val:b.underOdds!=null?b.underOdds.toFixed(2):'—',col:'var(--blue)'},
    {lbl:'P&L',      val:b.avePoints!=null?(b.avePoints>=0?'+':'')+b.avePoints.toFixed(2)+'pts':'—', col:b.avePoints!=null?(b.avePoints>=0?'var(--green)':'var(--red)'):'var(--muted)'},
    {lbl:'Timer',    val:b.timer!=null?b.timer+"'":'—',       col:'var(--text)'},
    {lbl:'Score',    val:score?`${score}${final?' → '+final:''}` :'—', col:'var(--text)'},
  ].map(c=>`<div class="ds-cell"><div class="ds-lbl">${c.lbl}</div><div class="ds-val" style="color:${c.col}">${c.val}</div></div>`).join('');

  // Odds movement content
  const oddsContent=snaps.length>=2
    ?`<div class="chart-wrap-lg"><canvas id="ochart"></canvas></div>`
    :b.isHistorical
      ?`<div class="chart-note" style="padding:30px 0"><div style="font-size:28px;margin-bottom:8px">📊</div>No time-series data<br><small>CBB stores final matched odds only.<br>Charts available for live-logged bets.</small></div>`
      :snaps.length===1
        ?`<div class="chart-note" style="padding:30px 0"><div style="font-size:24px;margin-bottom:8px">📍</div>
          <strong style="color:var(--text)">Over <span style="color:var(--orange)">${snaps[0].over??'—'}</span>${snaps[0].under?` / Under <span style="color:var(--blue)">${snaps[0].under}</span>`:''}</strong><br>
          <small>Chart builds as follow-up signals fire on this market.</small></div>`
        :`<div class="chart-note" style="padding:30px 0"><small>No odds data captured.</small></div>`;

  // Bet details table rows
  const detailRows=[
    b.signalStrategy&&b.signalStrategy!==b.strategy?`<tr><td>Signal</td><td>${esc(b.signalStrategy)}</td></tr>`:'',
    `<tr><td>Market</td><td>${esc(b.marketName||'—')}</td></tr>`,
    b.goals!=null?`<tr><td>Goals@Signal</td><td>${b.goals} (${b.goalsA}–${b.goalsB})</td></tr>`:'',
    `<tr><td>Market ID</td><td class="mono">${esc(b.marketId||'—')}</td></tr>`,
    `<tr><td>Selection</td><td class="mono">${esc(b.selectionId||'—')}</td></tr>`,
    b.cbbRunnerId?`<tr><td>Runner ID</td><td class="mono">${b.cbbRunnerId}</td></tr>`:'',
  ].filter(Boolean).join('');

  const ageHours=(Date.now()-new Date(b.placedAt).getTime())/3600000;
  const canLive=!b.isHistorical&&b.marketId;

  panel.innerHTML=`
    <div class="match-hdr">
      <div class="match-name-row">
        <div class="match-name">${esc(b.match||b.marketName||b.marketId||'Unknown')}</div>
        <div class="match-badges">
          <span class="badge ${o.cls}">${o.label}</span>
          ${b.isHistorical?`<span class="badge badge-pending">CBB</span>`:b.isCompanion?`<span class="badge badge-comp">🔗</span>`:b.success?`<span class="badge badge-ok">✓</span>`:`<span class="badge badge-fail">✗</span>`}
        </div>
      </div>
      <div class="match-sub">
        <span>📅 ${dateStr}</span>
        ${b.league?`<span>🏆 ${esc(b.league)}</span>`:''}
        ${b.overUnderValue?`<span>📊 O/U ${b.overUnderValue}</span>`:''}
        <span><span class="strat-pill">${esc(b.strategy||'—')}</span></span>
      </div>
    </div>

    <div class="detail-strip">${stripCells}</div>

    <div class="detail-cols">
      <div class="detail-left">
        ${betContextHTML(b)}
        ${strategyOverviewHTML(b)}
        ${!b.isHistorical?`<div class="section">
          <div class="sec-title">Match Result</div>
          <div class="result-row">
            <div><div class="r-lbl">Final Score (Home – Away)</div>
              <div style="display:flex;gap:5px;align-items:center">
                <input type="number" id="rga" min="0" max="30" value="${b.finalGoalsA??''}" placeholder="0">
                <span style="color:var(--muted)">–</span>
                <input type="number" id="rgb" min="0" max="30" value="${b.finalGoalsB??''}" placeholder="0">
              </div></div>
            <div style="display:flex;gap:6px;margin-top:8px">
              <button class="rbtn fetch-btn" id="fetch-btn" onclick="fetchResult('${esc(b.id)}')">🔍 Auto-fetch</button>
              <button class="rbtn save-btn" onclick="saveResult('${esc(b.id)}')">Save</button>
            </div>
          </div>
          <div id="rmsg"></div>
        </div>`:''}
      </div>
      <div class="section" style="display:flex;flex-direction:column">
        <div class="sec-title">
          Odds Movement <span id="snap-count" style="font-weight:400;color:var(--muted)">${snaps.length>0?`(${snaps.length} points)`:''}</span>
          ${canLive?`<button class="btn" id="live-odds-btn" onclick="triggerLiveOdds('${esc(b.id)}')" style="padding:2px 8px;font-size:10px">↻ Live</button>`:''}
        </div>
        ${oddsContent}
      </div>
    </div>

    <div class="detail-foot">
      <div class="section">
        <div class="sec-title">Bet Details</div>
        <table><tr><th>Field</th><th>Value</th></tr>${detailRows}</table>
      </div>
      <div class="section">
        <div class="sec-title">Price Snapshots <span id="snap-count2" style="font-weight:400">${snaps.length>0?`(${snaps.length})`:''}</span></div>
        ${snaps.length>0
          ?`<table><tr><th>Time</th><th>Over</th><th>Under</th></tr>
            ${snaps.map((s,i)=>`<tr>
              <td class="mono">${new Date(s.at).toLocaleTimeString('en-GB')}${i===0?'<span style="color:var(--muted);font-size:10px"> (signal)</span>':''}</td>
              <td style="color:var(--orange);font-weight:600">${s.over!=null?s.over.toFixed(2):'—'}</td>
              <td style="color:var(--blue);font-weight:600">${s.under!=null?s.under.toFixed(2):'—'}</td>
            </tr>`).join('')}</table>`
          :`<div style="padding:16px 0;text-align:center;color:var(--muted);font-size:12px">${canLive?'Click ↻ Live above to capture the first price point':'No price data available'}</div>`}
      </div>
    </div>

    ${sameMarketHTML(b)}
  `;

  if(snaps.length>=2) drawOddsChart(snaps);
  // Auto-fetch live price for in-play bets (< 4h old, fewer than 5 snapshots already)
  if(canLive&&ageHours<4&&snaps.length<5) fetchLiveSnapshot(b.id);
}

function drawOddsChart(snaps){
  if(oddsChart){oddsChart.destroy();oddsChart=null;}
  const ctx=document.getElementById('ochart');if(!ctx)return;
  // Make the parent fill its container height
  const wrap=ctx.parentElement;if(wrap)wrap.style.height=wrap.style.height||'100%';
  oddsChart=new Chart(ctx,{type:'line',data:{
    labels:snaps.map(s=>new Date(s.at).toLocaleTimeString('en-GB',{hour:'2-digit',minute:'2-digit'})),
    datasets:[{label:'Over',data:snaps.map(s=>s.over??null),borderColor:'#f0883e',backgroundColor:'rgba(240,136,62,.08)',tension:.35,pointRadius:4,borderWidth:2.5,fill:true},
      {label:'Under',data:snaps.map(s=>s.under??null),borderColor:'#58a6ff',backgroundColor:'rgba(88,166,255,.08)',tension:.35,pointRadius:4,borderWidth:2.5,fill:true}]},
    options:{responsive:true,maintainAspectRatio:false,interaction:{mode:'index',intersect:false},
      plugins:{legend:{labels:{color:'#8b949e',boxWidth:10,font:{size:11}}},tooltip:{backgroundColor:'#1c2128',borderColor:'#30363d',borderWidth:1,titleColor:'#e6edf3',bodyColor:'#8b949e',padding:8,callbacks:{label:c=>` ${c.dataset.label}: ${c.parsed.y?.toFixed(2)??'—'}`}}},
      scales:{x:{grid:{color:'rgba(48,54,61,.5)'},ticks:{color:'#8b949e',font:{size:10}}},y:{grid:{color:'rgba(48,54,61,.5)'},ticks:{color:'#8b949e',font:{size:10}},title:{display:true,text:'Decimal Odds',color:'#8b949e',font:{size:10}}}}}});
}

// ─── Delete bet ───────────────────────────────────────────────────────────────
async function deleteFootballBet(betId){
  if(!confirm('Delete this bet from history?'))return;
  try{const r=await fetch(`/football/api/bets/${encodeURIComponent(betId)}`,{method:'DELETE'});
    if(r.ok){selectedId=null;await reload();}
    else{alert('Delete failed');}}
  catch(e){alert('Delete failed: '+e.message);}
}

// ─── Result actions ───────────────────────────────────────────────────────────
async function fetchResult(betId){
  const btn=document.getElementById('fetch-btn'),msg=document.getElementById('rmsg');
  btn.disabled=true;btn.textContent='⏳ Fetching…';msg.textContent='';
  try{const r=await fetch(`/football/api/bets/${encodeURIComponent(betId)}/fetch-result`,{method:'POST'});
    const d=await r.json();if(d.ok){msg.className='rmsg ok';msg.textContent=`✓ ${d.finalGoalsA}–${d.finalGoalsB} (${d.updated} updated)`;await reload();}
    else{msg.className='rmsg err';msg.textContent=`✗ ${d.reason}`;btn.disabled=false;btn.textContent='🔍 Auto-fetch';}}
  catch(e){msg.className='rmsg err';msg.textContent=`✗ ${e.message}`;btn.disabled=false;btn.textContent='🔍 Auto-fetch';}
}
async function saveResult(betId){
  const gA=parseInt(document.getElementById('rga').value),gB=parseInt(document.getElementById('rgb').value),msg=document.getElementById('rmsg');
  if(isNaN(gA)||isNaN(gB)){msg.className='rmsg err';msg.textContent='Enter both scores';return;}
  try{const r=await fetch(`/football/api/bets/${encodeURIComponent(betId)}`,{method:'PATCH',headers:{'Content-Type':'application/json'},body:JSON.stringify({finalGoalsA:gA,finalGoalsB:gB})});
    const d=await r.json();if(d.id){msg.className='rmsg ok';msg.textContent=`✓ Saved — result: ${d.result}`;await reload();}
    else{msg.className='rmsg err';msg.textContent=`✗ ${d.error||'error'}`;}}
  catch(e){msg.className='rmsg err';msg.textContent=`✗ ${e.message}`;}
}

// ─── CBB import ───────────────────────────────────────────────────────────────
async function importCBB(){
  const btn=document.getElementById('import-btn');btn.disabled=true;btn.textContent='⏳ Importing…';
  try{const r=await fetch('/football/api/import-cbb',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({from:'2025-01-01',to:new Date().toISOString().split('T')[0]})});
    const d=await r.json();if(d.ok){btn.textContent=`✓ ${d.imported} new, ${d.updated} updated`;await reload();}else btn.textContent=`✗ ${d.error}`;}
  catch(e){btn.textContent=`✗ ${e.message}`;}
  setTimeout(()=>{btn.textContent='⬇ Import CBB';btn.disabled=false;},5000);
}

// ─── Exceptions ───────────────────────────────────────────────────────────────
let allExceptions = [];

async function loadExceptions() {
  try {
    const r = await fetch('/football/api/exceptions');
    allExceptions = await r.json();
    const reasons = [...new Set(allExceptions.map(e => e.reason).filter(Boolean))].sort();
    const sel = document.getElementById('exc-reason'), cur = sel.value;
    sel.innerHTML = '<option value="">All reasons</option>' + reasons.map(r => `<option${r===cur?' selected':''}>${esc(r)}</option>`).join('');
  } catch(e) { allExceptions = []; }
  renderExceptions();
}

function renderExceptions() {
  const src = document.getElementById('exc-source').value;
  const rsn = document.getElementById('exc-reason').value;
  const items = allExceptions.filter(e => {
    if(src && e.source !== src) return false;
    if(rsn && e.reason !== rsn) return false;
    return true;
  });
  document.getElementById('exc-count').textContent = `— ${items.length} of ${allExceptions.length} shown`;
  const el = document.getElementById('exc-list');
  if(!items.length) { el.innerHTML = `<div class="no-bets">No exceptions${allExceptions.length?` matching filters`:` recorded yet`}</div>`; return; }
  el.innerHTML = `<table style="width:100%;border-collapse:collapse;font-size:12px">
    <thead><tr>
      <th style="text-align:left;padding:6px 10px;color:var(--muted);font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:.4px;border-bottom:1px solid var(--border)">Time</th>
      <th style="text-align:left;padding:6px 10px;color:var(--muted);font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:.4px;border-bottom:1px solid var(--border)">Source</th>
      <th style="text-align:left;padding:6px 10px;color:var(--muted);font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:.4px;border-bottom:1px solid var(--border)">Match / Teams</th>
      <th style="text-align:left;padding:6px 10px;color:var(--muted);font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:.4px;border-bottom:1px solid var(--border)">Strategy</th>
      <th style="text-align:left;padding:6px 10px;color:var(--muted);font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:.4px;border-bottom:1px solid var(--border)">Market</th>
      <th style="text-align:left;padding:6px 10px;color:var(--muted);font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:.4px;border-bottom:1px solid var(--border)">Reason</th>
    </tr></thead>
    <tbody>${items.map(e => {
      const dt = new Date(e.at);
      const dateStr = dt.toLocaleDateString('en-GB',{day:'numeric',month:'short'});
      const timeStr = dt.toLocaleTimeString('en-GB',{hour:'2-digit',minute:'2-digit'});
      const matchName = e.match || (e.teamA&&e.teamB ? `${e.teamA} vs ${e.teamB}` : '—');
      const srcBadge = e.source==='bfbm'
        ? `<span class="badge badge-comp">BFBM</span>`
        : `<span class="badge badge-ok">IPG</span>`;
      const isCBBfail = e.reason && e.reason.startsWith('CBB rejected');
      return `<tr style="border-bottom:1px solid rgba(48,54,61,.4)">
        <td style="padding:7px 10px;white-space:nowrap;color:var(--muted);font-size:11px">${dateStr}<br>${timeStr}</td>
        <td style="padding:7px 10px">${srcBadge}</td>
        <td style="padding:7px 10px;max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${esc(matchName)}</td>
        <td style="padding:7px 10px"><span class="strat-pill">${esc(e.strategy||'—')}</span></td>
        <td style="padding:7px 10px;color:var(--muted)">${e.overUnderValue?`O/U ${e.overUnderValue}`:'—'}</td>
        <td style="padding:7px 10px;color:${isCBBfail?'var(--orange)':'var(--red)'}">${esc(e.reason||'—')}</td>
      </tr>`;
    }).join('')}</tbody></table>`;
}

// ─── Analytics sidebar ────────────────────────────────────────────────────────
function toggleSidebar(){
  const sb=document.getElementById('a-sidebar');sb.classList.toggle('hidden');
}

function renderSidebar(){
  const body=document.getElementById('chart-toggles');
  body.innerHTML=CHART_LIB.map(c=>`
    <div class="chart-toggle" draggable="true" data-id="${c.id}" ondragstart="dragStart(event)" ondragover="dragOver(event)" ondrop="dropChart(event)">
      <span class="drag-handle">⠿</span>
      <input type="checkbox" id="ct-${c.id}" ${activeCharts.includes(c.id)?'checked':''} onchange="toggleChart('${c.id}',this.checked)">
      <div><div class="ct-label">${c.label}</div><div class="ct-desc">${c.desc}</div></div>
    </div>`).join('');
}

function toggleChart(id,on){
  if(on){if(!activeCharts.includes(id))activeCharts.push(id);}
  else activeCharts=activeCharts.filter(x=>x!==id);
  saveChartPrefs(activeCharts);renderAnalytics();
}

let dragSrc=null;
function dragStart(e){dragSrc=e.currentTarget;e.currentTarget.classList.add('dragging');}
function dragOver(e){e.preventDefault();}
function dropChart(e){
  e.preventDefault();
  const tgt=e.currentTarget;
  if(!dragSrc||dragSrc===tgt)return;
  dragSrc.classList.remove('dragging');
  const srcId=dragSrc.dataset.id,tgtId=tgt.dataset.id;
  const si=activeCharts.indexOf(srcId),ti=activeCharts.indexOf(tgtId);
  if(si>=0&&ti>=0){activeCharts.splice(si,1);activeCharts.splice(ti,0,srcId);}
  else if(si>=0){activeCharts.splice(si,1);activeCharts.push(srcId);}
  saveChartPrefs(activeCharts);renderSidebar();renderAnalytics();
}

// ─── Analytics rendering ──────────────────────────────────────────────────────
function renderAnalytics(){
  Object.values(aCharts).forEach(c=>c.destroy());aCharts={};
  chartBets = analyticsMarket ? allBets.filter(b=>b.overUnderValue===analyticsMarket) : allBets;

  const won=chartBets.filter(b=>b.result==='won').length,lost=chartBets.filter(b=>b.result==='lost').length,s=won+lost;
  const pl=chartBets.reduce((a,b)=>a+(b.avePoints??0),0);

  const yield_=s>0?(pl/s*100):0;
  const byDay={};for(const b of chartBets){if(b.avePoints==null)continue;const d=b.placedAt?.split('T')[0]||'?';byDay[d]=(byDay[d]||0)+b.avePoints;}
  const daysWon=Object.values(byDay).filter(v=>v>0).length,daysLost=Object.values(byDay).filter(v=>v<0).length;
  const oddsArr=chartBets.filter(b=>b.overOdds!=null).map(b=>b.overOdds);
  const avgOdds=oddsArr.length?oddsArr.reduce((a,b)=>a+b,0)/oddsArr.length:null;
  const mktLabel=analyticsMarket?` — O/U ${analyticsMarket}`:'';
  document.getElementById('a-summary').innerHTML=[
    ['Total Bets'+mktLabel,chartBets.length,'var(--blue)'],['Won',won,'var(--green)'],['Lost',lost,'var(--red)'],
    ['Strike Rate',s>0?(won/s*100).toFixed(1)+'%':'—',won>=lost?'var(--green)':'var(--red)'],
    ['Avg Odds',avgOdds!=null?avgOdds.toFixed(2):'—','var(--orange)'],
    ['Yield',s>0?(yield_>=0?'+':'')+yield_.toFixed(1)+'%':'—',yield_>=0?'var(--green)':'var(--red)'],
    ['P&L (pts)',(pl>=0?'+':'')+pl.toFixed(2),pl>=0?'var(--green)':'var(--red)'],
    ['Days Won',daysWon,'var(--green)'],['Days Lost',daysLost,'var(--red)'],
  ].map(([l,v,c])=>`<div class="sum-card"><div class="sc-val" style="color:${c}">${v}</div><div class="sc-lbl">${l}</div></div>`).join('');

  const ordered=activeCharts.map(id=>CHART_LIB.find(c=>c.id===id)).filter(Boolean);
  document.getElementById('a-charts').innerHTML=`
    <button class="btn hi" onclick="toggleSidebar()" style="margin-bottom:10px;grid-column:1/-1">⚙ Manage Charts</button>
    ${ordered.map(c=>`<div class="chart-card${c.tall?' tall':''}" id="cc-${c.id}"><div class="cct">${c.label}</div><div class="chart-wrap"><canvas id="ac-${c.id}"></canvas></div></div>`).join('')}
  `;
  setTimeout(()=>ordered.forEach(c=>{try{window[c.fn]();}catch(_){}}),0);
}

function setAnalyticsMkt(mkt){
  analyticsMarket=mkt;
  document.querySelectorAll('.mf-btn').forEach(b=>b.classList.toggle('active',b.dataset.mkt===mkt));
  renderAnalytics();
}

// ─── Chart helpers ────────────────────────────────────────────────────────────
const CO=(ex={})=>({responsive:true,maintainAspectRatio:false,
  plugins:{legend:{display:false},tooltip:{backgroundColor:'#1c2128',borderColor:'#30363d',borderWidth:1,titleColor:'#e6edf3',bodyColor:'#8b949e',padding:8}},
  scales:{x:{grid:{color:'rgba(48,54,61,.4)'},ticks:{color:'#8b949e',font:{size:10}}},y:{grid:{color:'rgba(48,54,61,.4)'},ticks:{color:'#8b949e',font:{size:10}}}},
  ...ex});

function mkChart(id,type,data,options){
  if(aCharts[id])aCharts[id].destroy();
  const ctx=document.getElementById(`ac-${id}`);if(!ctx)return;
  aCharts[id]=new Chart(ctx,{type,data,options});
}

// ─── Individual chart functions ───────────────────────────────────────────────
function drawStratChart(){
  if(aCharts.stratPerf)aCharts.stratPerf.destroy();
  const ctx=document.getElementById('ac-stratPerf');if(!ctx)return;
  const m={};
  for(const b of chartBets){
    if(!b.strategy||b.result==='pending')continue;
    if(!m[b.strategy])m[b.strategy]={w:0,l:0};
    if(b.result==='won')m[b.strategy].w++;else m[b.strategy].l++;
  }
  const rows=Object.entries(m).map(([s,v])=>({s,...v,tot:v.w+v.l})).filter(r=>r.tot>0).sort((a,b)=>b.tot-a.tot).slice(0,20);
  if(!rows.length){ctx.parentElement.innerHTML='<div class="chart-note">No settled bets yet</div>';return;}
  aCharts.stratPerf=new Chart(ctx,{type:'bar',data:{labels:rows.map(r=>r.s),
    datasets:[{label:'Won',data:rows.map(r=>r.w),backgroundColor:'rgba(63,185,80,.75)',borderRadius:3},
              {label:'Lost',data:rows.map(r=>r.l),backgroundColor:'rgba(248,81,73,.75)',borderRadius:3}]},
    options:{...CO(),indexAxis:'y',plugins:{...CO().plugins,legend:{display:true,labels:{color:'#8b949e',boxWidth:10,font:{size:10}}}},scales:{x:{...CO().scales.x,stacked:true},y:{...CO().scales.y,stacked:true,ticks:{color:'#8b949e',font:{size:10}}}}}});
}

function drawPLChart(){
  const pts=chartBets.filter(b=>b.avePoints!=null).sort((a,b)=>new Date(a.placedAt)-new Date(b.placedAt));
  if(!pts.length){const c=document.getElementById('ac-cumPL');if(c)c.parentElement.innerHTML='<div class="chart-note">No P&L data yet</div>';return;}
  // Aggregate to one point per day so the line is clean
  const daily={};for(const b of pts){const d=b.placedAt.split('T')[0];daily[d]=(daily[d]||0)+b.avePoints;}
  const days=Object.keys(daily).sort();
  let cum=0;const data=days.map(d=>{cum=parseFloat((cum+daily[d]).toFixed(2));return{x:d,y:cum};});
  mkChart('cumPL','line',{datasets:[{label:'Cumulative P&L',data,borderColor:cum>=0?'#3fb950':'#f85149',backgroundColor:cum>=0?'rgba(63,185,80,.08)':'rgba(248,81,73,.08)',tension:.3,pointRadius:3,borderWidth:2,fill:true}]},
    {...CO(),plugins:{...CO().plugins,tooltip:{...CO().plugins.tooltip,callbacks:{label:c=>`${c.parsed.y>=0?'+':''}${c.parsed.y.toFixed(2)} pts`,title:([c])=>c.label}}},
     scales:{x:{type:'category',grid:{color:'rgba(48,54,61,.4)'},ticks:{color:'#8b949e',font:{size:10},maxTicksLimit:12}},y:{grid:{color:'rgba(48,54,61,.4)'},ticks:{color:'#8b949e',font:{size:10}},title:{display:true,text:'Points',color:'#8b949e',font:{size:10}}}}});
}

function drawVolChart(){
  const m={};
  for(const b of chartBets){
    if(b.result==='pending')continue;
    const d=b.placedAt?.split('T')[0]||'?';
    if(!m[d])m[d]={w:0,l:0};
    if(b.result==='won')m[d].w++;else m[d].l++;
  }
  const days=Object.keys(m).sort().slice(-60);
  mkChart('volume','bar',{labels:days,datasets:[{label:'Won',data:days.map(d=>m[d].w),backgroundColor:'rgba(63,185,80,.7)',borderRadius:2},{label:'Lost',data:days.map(d=>m[d].l),backgroundColor:'rgba(248,81,73,.7)',borderRadius:2}]},
    {...CO(),plugins:{...CO().plugins,legend:{display:true,labels:{color:'#8b949e',boxWidth:10,font:{size:10}}}},scales:{x:{...CO().scales.x,stacked:true,ticks:{color:'#8b949e',font:{size:10},maxTicksLimit:12}},y:{...CO().scales.y,stacked:true}}});
}


function drawMktOverview(){
  const ctx=document.getElementById('ac-mktOverview');if(!ctx)return;
  const wrap=ctx.parentElement;wrap.style.height='auto';
  // Gather all three metrics per market in one pass
  const m={};
  for(const b of chartBets){
    const k=b.overUnderValue;if(!k)continue;
    if(!m[k])m[k]={w:0,l:0,odds:[],pl:0,pln:0};
    if(b.result==='won')m[k].w++;
    else if(b.result==='lost')m[k].l++;
    if(b.overOdds!=null)m[k].odds.push(b.overOdds);
    if(b.avePoints!=null){m[k].pl+=b.avePoints;m[k].pln++;}
  }
  const mkts=Object.keys(m).sort((a,b)=>parseFloat(a)-parseFloat(b));
  if(!mkts.length){wrap.innerHTML='<div class="chart-note">No data yet</div>';return;}

  const th=`padding:10px 14px;font-size:9px;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;font-weight:600;white-space:nowrap;text-align:right`;
  const td=(val,col)=>`<td style="padding:10px 14px;text-align:right;white-space:nowrap;font-size:12px;font-weight:600;color:${col}">${val}</td>`;

  wrap.style.overflow='auto';
  wrap.innerHTML=`<table style="width:100%;border-collapse:collapse">
    <thead><tr style="border-bottom:1px solid var(--border)">
      <th style="${th};text-align:left">Market</th>
      <th style="${th}">Settled</th>
      <th style="${th}">W / L</th>
      <th style="${th}">Strike</th>
      <th style="${th}">Avg Odds</th>
      <th style="${th}">Yield</th>
      <th style="${th}">P&L</th>
    </tr></thead>
    <tbody>${mkts.map(k=>{
      const v=m[k],settled=v.w+v.l;
      const sr=settled>0?v.w/settled*100:null;
      const avg=v.odds.length?v.odds.reduce((a,b)=>a+b,0)/v.odds.length:null;
      const yld=v.pln>0?v.pl/v.pln*100:null;
      const srCol=sr!=null?(sr>=50?'var(--green)':'var(--red)'):'var(--muted)';
      const yCol=yld!=null?(yld>=0?'var(--green)':'var(--red)'):'var(--muted)';
      const plCol=v.pln>0?(v.pl>=0?'var(--green)':'var(--red)'):'var(--muted)';
      return`<tr style="border-bottom:1px solid rgba(48,54,61,.4)">
        <td style="padding:10px 14px;font-size:12px;font-weight:700;white-space:nowrap">O/U ${k}</td>
        ${td(settled>0?settled:'—','var(--fg)')}
        ${td(settled>0?`${v.w}W / ${v.l}L`:'—','var(--muted)')}
        ${td(sr!=null?sr.toFixed(1)+'%':'—',srCol)}
        ${td(avg!=null?avg.toFixed(2):'—','var(--orange)')}
        ${td(yld!=null?(yld>=0?'+':'')+yld.toFixed(1)+'%':'—',yCol)}
        ${td(v.pln>0?(v.pl>=0?'+':'')+v.pl.toFixed(2)+'pts':'—',plCol)}
      </tr>`;
    }).join('')}</tbody>
  </table>`;
}

function drawOddsDist(){
  const settled=chartBets.filter(b=>b.overOdds!=null&&(b.result==='won'||b.result==='lost'));
  if(!settled.length){const c=document.getElementById('ac-oddsDist');if(c)c.parentElement.innerHTML='<div class="chart-note">No settled bets with odds yet</div>';return;}
  const bkts={};for(const b of settled){const k=(Math.floor(b.overOdds*4)/4).toFixed(2);if(!bkts[k])bkts[k]={w:0,l:0};if(b.result==='won')bkts[k].w++;else bkts[k].l++;}
  const e=Object.entries(bkts).sort((a,b)=>parseFloat(a[0])-parseFloat(b[0]));
  const implied=e.map(([k])=>parseFloat((1/parseFloat(k)*100).toFixed(1)));
  const actual=e.map(([,v])=>v.w+v.l>0?parseFloat((v.w/(v.w+v.l)*100).toFixed(1)):0);
  // Tooltip shows count and edge (actual minus implied)
  const counts=e.map(([,v])=>v.w+v.l);
  mkChart('oddsDist','bar',{labels:e.map(([k,v])=>`${k} (${v.w+v.l})`),datasets:[
    {label:'Implied Prob %',data:implied,backgroundColor:'rgba(88,166,255,.5)',borderRadius:3},
    {label:'Actual Strike Rate %',data:actual,backgroundColor:'rgba(63,185,80,.7)',borderRadius:3}
  ]},{...CO(),plugins:{...CO().plugins,legend:{display:true,labels:{color:'#8b949e',boxWidth:10,font:{size:10}}},
      tooltip:{...CO().plugins.tooltip,callbacks:{afterBody:([c])=>{const i=implied[c.dataIndex],a=actual[c.dataIndex];const edge=a-i;return[`Edge: ${edge>=0?'+':''}${edge.toFixed(1)}%`];}}}},
    scales:{x:{...CO().scales.x,title:{display:true,text:'Decimal Odds Bucket',color:'#8b949e',font:{size:10}}},
            y:{...CO().scales.y,min:0,ticks:{color:'#8b949e',font:{size:10},callback:v=>v+'%'},title:{display:true,text:'%',color:'#8b949e',font:{size:10}}}}});
}

function drawStratPL(){
  const m={},cnt={};
  for(const b of chartBets){if(!b.strategy||b.avePoints==null)continue;m[b.strategy]=(m[b.strategy]||0)+b.avePoints;cnt[b.strategy]=(cnt[b.strategy]||0)+1;}
  // Show ALL strategies best→worst so losing strategies are never hidden
  const e=Object.entries(m).sort((a,b)=>b[1]-a[1]);
  const vals=e.map(([,v])=>parseFloat(v.toFixed(2)));
  mkChart('stratPL','bar',{labels:e.map(([k])=>k),datasets:[{label:'P&L (pts)',data:vals,backgroundColor:vals.map(v=>v>=0?'rgba(63,185,80,.7)':'rgba(248,81,73,.7)'),borderRadius:3}]},
    {...CO(),plugins:{...CO().plugins,tooltip:{...CO().plugins.tooltip,callbacks:{label:c=>`${c.parsed.y>=0?'+':''}${c.parsed.y.toFixed(2)}pts (${cnt[e[c.dataIndex][0]]} bets)`}}},
     scales:{x:{...CO().scales.x},y:{...CO().scales.y,title:{display:true,text:'Points',color:'#8b949e',font:{size:10}}}}});
}

function drawStratOdds(){
  const m={};for(const b of chartBets){if(!b.strategy||b.overOdds==null)continue;if(!m[b.strategy])m[b.strategy]=[];m[b.strategy].push(b.overOdds);}
  const e=Object.entries(m).map(([s,a])=>({s,avg:a.reduce((x,y)=>x+y,0)/a.length,min:Math.min(...a),max:Math.max(...a),cnt:a.length})).sort((a,b)=>b.avg-a.avg).slice(0,20);
  mkChart('stratOdds','bar',{labels:e.map(x=>`${x.s} (${x.cnt})`),datasets:[{label:'Avg Odds',data:e.map(x=>parseFloat(x.avg.toFixed(2))),backgroundColor:'rgba(240,136,62,.65)',borderRadius:3}]},
    {...CO(),plugins:{...CO().plugins,tooltip:{...CO().plugins.tooltip,callbacks:{label:c=>[` Avg: ${c.parsed.y.toFixed(2)}`,` Range: ${e[c.dataIndex].min.toFixed(2)}–${e[c.dataIndex].max.toFixed(2)}`]}}},
     scales:{x:{...CO().scales.x},y:{...CO().scales.y,suggestedMin:1,title:{display:true,text:'Decimal Odds',color:'#8b949e',font:{size:10}}}}});
}

function drawTimerDist(){
  const bkts=Array(10).fill(0);for(const b of chartBets){if(b.timer==null)continue;bkts[Math.min(9,Math.floor(b.timer/10))]++;}
  if(bkts.every(v=>v===0)){const c=document.getElementById('ac-timerDist');if(c)c.parentElement.innerHTML='<div class="chart-note">No timer data — only InPlayGuru signals include match minute</div>';return;}
  const labels=['0-9','10-19','20-29','30-39','40-49','50-59','60-69','70-79','80-89','90+'];
  mkChart('timerDist','bar',{labels,datasets:[{label:'Bets',data:bkts,backgroundColor:'rgba(188,140,255,.65)',borderRadius:3}]},
    {...CO(),scales:{x:{...CO().scales.x,title:{display:true,text:'Match Minute',color:'#8b949e',font:{size:10}}},y:{...CO().scales.y}}});
}

function drawHourDist(){
  const bkts=Array(24).fill(0);for(const b of chartBets){if(!b.placedAt)continue;bkts[new Date(b.placedAt).getHours()]++;}
  mkChart('hourDist','bar',{labels:[...Array(24).keys()].map(h=>`${h}:00`),datasets:[{label:'Bets',data:bkts,backgroundColor:'rgba(88,166,255,.55)',borderRadius:3}]},
    {...CO(),scales:{x:{...CO().scales.x,title:{display:true,text:'Hour of Day',color:'#8b949e',font:{size:10}}},y:{...CO().scales.y}}});
}

function drawDOWDist(){
  const days=['Mon','Tue','Wed','Thu','Fri','Sat','Sun'],bkts=Array(7).fill(0);
  for(const b of chartBets){if(!b.placedAt)continue;bkts[(new Date(b.placedAt).getDay()+6)%7]++;}
  mkChart('dowDist','bar',{labels:days,datasets:[{label:'Bets',data:bkts,backgroundColor:'rgba(227,179,65,.65)',borderRadius:3}]},
    {...CO(),scales:{x:{...CO().scales.x},y:{...CO().scales.y}}});
}

function drawMonthlyPL(){
  const m={};for(const b of chartBets){if(b.avePoints==null)continue;const k=b.placedAt?.slice(0,7)||'?';m[k]=(m[k]||0)+b.avePoints;}
  const e=Object.entries(m).sort();
  mkChart('monthlyPL','bar',{labels:e.map(([k])=>k),datasets:[{label:'P&L (pts)',data:e.map(([,v])=>parseFloat(v.toFixed(2))),backgroundColor:e.map(([,v])=>v>=0?'rgba(63,185,80,.7)':'rgba(248,81,73,.7)'),borderRadius:3}]},
    {...CO(),scales:{x:{...CO().scales.x,title:{display:true,text:'Month',color:'#8b949e',font:{size:10}}},y:{...CO().scales.y,title:{display:true,text:'Points',color:'#8b949e',font:{size:10}}}}});
}

function drawScoreDist(){
  const m={};for(const b of chartBets){if(b.goals==null)continue;m[b.goals]=(m[b.goals]||0)+1;}
  const e=Object.entries(m).sort((a,b)=>parseInt(a[0])-parseInt(b[0]));
  if(!e.length){const c=document.getElementById('ac-scoreDist');if(c)c.parentElement.innerHTML='<div class="chart-note">No goals data — only InPlayGuru signals include goals at signal</div>';return;}
  mkChart('scoreDist','bar',{labels:e.map(([k])=>`${k} goals`),datasets:[{label:'Bets',data:e.map(([,v])=>v),backgroundColor:'rgba(63,185,80,.55)',borderRadius:3}]},
    {...CO(),scales:{x:{...CO().scales.x,title:{display:true,text:'Goals at Signal',color:'#8b949e',font:{size:10}}},y:{...CO().scales.y}}});
}

function drawCumPLByMarket(){
  // Always uses allBets so all markets are visible even when a filter is active
  const mkts=[{v:'0.5',color:'#f0883e'},{v:'1.5',color:'#58a6ff'},{v:'2.5',color:'#3fb950'}];
  const bgMap={'#f0883e':'rgba(240,136,62,.08)','#58a6ff':'rgba(88,166,255,.08)','#3fb950':'rgba(63,185,80,.08)'};

  // Build per-market daily P&L maps and collect all dates into one shared timeline
  const mktDaily={};const allDates=new Set();
  for(const{v}of mkts){
    const pts=allBets.filter(b=>b.overUnderValue===v&&b.avePoints!=null);
    if(!pts.length)continue;
    mktDaily[v]={};
    for(const b of pts){const d=b.placedAt.split('T')[0];mktDaily[v][d]=(mktDaily[v][d]||0)+b.avePoints;allDates.add(d);}
  }
  if(!Object.keys(mktDaily).length){const c=document.getElementById('ac-cumPLByMarket');if(c)c.parentElement.innerHTML='<div class="chart-note">No P&L data yet</div>';return;}

  const days=[...allDates].sort();
  const datasets=[];
  for(const{v,color}of mkts){
    if(!mktDaily[v])continue;
    const lastDay=Object.keys(mktDaily[v]).sort().pop();
    let cum=0;const data=[];
    for(const d of days){
      if(mktDaily[v][d]!=null) cum=parseFloat((cum+mktDaily[v][d]).toFixed(2));
      data.push({x:d,y:cum});
      if(d===lastDay)break; // don't project line past last bet for this market
    }
    datasets.push({label:`O/U ${v}`,data,borderColor:color,backgroundColor:bgMap[color],tension:.3,pointRadius:3,borderWidth:2,fill:false});
  }
  mkChart('cumPLByMarket','line',{datasets},
    {...CO(),plugins:{...CO().plugins,legend:{display:true,labels:{color:'#8b949e',boxWidth:10,font:{size:10}}},
      tooltip:{...CO().plugins.tooltip,callbacks:{label:c=>`O/U ${c.dataset.label.split(' ')[1]}: ${c.parsed.y>=0?'+':''}${c.parsed.y.toFixed(2)} pts`}}},
     scales:{x:{type:'category',grid:{color:'rgba(48,54,61,.4)'},ticks:{color:'#8b949e',font:{size:10},maxTicksLimit:12}},
             y:{grid:{color:'rgba(48,54,61,.4)'},ticks:{color:'#8b949e',font:{size:10}},title:{display:true,text:'Points',color:'#8b949e',font:{size:10}}}}});
}

// ─── Helpers ──────────────────────────────────────────────────────────────────
function trunc(s,n){return s&&s.length>n?s.slice(0,n)+'…':s||''}
function esc(s){return String(s??'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;')}

// ─── Init ─────────────────────────────────────────────────────────────────────
// ─── SportMonks live data ─────────────────────────────────────────────────────
let smData = null;
let smAutoRefresh = null;

async function loadSmLive() {
  try {
    const r = await fetch('/football/api/sportmonks/live');
    smData = await r.json();
    renderSmLive();
    // Auto-refresh every 50s while tab is active
    clearInterval(smAutoRefresh);
    smAutoRefresh = setInterval(() => { if(currentTab==='sportmonks') loadSmLive(); }, 50000);
  } catch(e) {
    document.getElementById('sm-status-txt').textContent = 'Failed to load: ' + e.message;
  }
}

function smToggleRow(el) {
  el.classList.toggle('open');
}

function renderSmLive() {
  const d = smData;
  if (!d) return;

  const dot = document.getElementById('sm-dot');
  const statusTxt = document.getElementById('sm-status-txt');
  const lastPoll = document.getElementById('sm-last-poll');
  const fixCount = document.getElementById('sm-fixture-count');
  const noKey = document.getElementById('sm-no-key');
  const fixturesWrap = document.getElementById('sm-fixtures-wrap');

  if (!d.apiKeySet) {
    dot.className = 'sm-status-dot warn';
    statusTxt.textContent = 'API key not set';
    noKey.style.display = '';
    fixturesWrap.style.display = 'none';
    return;
  }
  noKey.style.display = 'none';
  fixturesWrap.style.display = '';

  dot.className = 'sm-status-dot live';
  statusTxt.textContent = 'Polling every 45s';
  lastPoll.textContent = d.lastPolledAt ? new Date(d.lastPolledAt).toLocaleTimeString('en-GB') : '�';
  fixCount.textContent = d.fixtureCount ?? 0;

  // Fixture cards
  const cardsEl = document.getElementById('sm-fixture-cards');
  const sub = document.getElementById('sm-fixtures-sub');
  sub.textContent = `(${(d.fixtures||[]).length} matches)`;

  if (!d.fixtures || !d.fixtures.length) {
    cardsEl.innerHTML = '<div style="text-align:center;padding:30px;color:var(--muted);font-size:12px">No live fixtures at the moment � poll runs every 45s</div>';
  } else {
    // Build signal map per fixtureId
    const sigMap = {};
    for (const s of (d.signalsFired||[])) {
      if (!sigMap[s.fixtureId]) sigMap[s.fixtureId] = [];
      const entry = sigMap[s.fixtureId].find(e => e.strategy === s.strategy);
      if (!entry) sigMap[s.fixtureId].push({ strategy: s.strategy, firedAt: s.firedAt, minute: s.minute });
    }

    const mkBar = (h, a, cls='') => {
      const t = (h||0)+(a||0)||1;
      const hp = ((h||0)/t*100).toFixed(0);
      return `<div class="sm-bar-wrap ${cls}"><div class="sm-bar-home" style="width:${hp}%"></div><div class="sm-bar-away" style="width:${100-hp}%"></div></div>`;
    };
    const mkDetailStat = (label, h, a, total, alertCls='', hiH='', hiA='', suffix='') => `
      <div class="sm-detail-stat ${alertCls}">
        <div class="sm-ds-lbl"><span>${label}</span><span style="color:var(--muted)">${total}</span></div>
        <div class="sm-ds-vals">
          <span class="${hiH}">${h}${suffix}</span>
          ${mkBar(h, a)}
          <span class="${hiA}">${a}${suffix}</span>
        </div>
      </div>`;

    const rows = d.fixtures.map(f => {
      const sigs = sigMap[f.fixtureId] || [];
      const pressTotal = (f.pressureHome||0) + (f.pressureAway||0) || 100;

      // Collapsed header inline stats
      const xgHp = Math.min((f.xgHome / Math.max(f.xgTotal, 0.01)) * 100, 100).toFixed(0);
      const presHp = ((f.pressureHome / pressTotal) * 100).toFixed(0);
      const danTotal = (f.dangerousHome||0) + (f.dangerousAway||0) || 1;
      const danHp = ((f.dangerousHome / danTotal) * 100).toFixed(0);

      const sigHtml = sigs.length
        ? sigs.map(s => `<span class="sm-signal-pill" title="Min ${s.minute}">${esc(s.strategy.replace('SM_',''))}</span>`).join('')
        : '';

      // Expanded detail � two columns
      const leftStats = [
        mkDetailStat('xG', f.xgHome.toFixed(2), f.xgAway.toFixed(2), f.xgTotal.toFixed(2)+' total',
          f.xgTotal>=1.5?'alert-xg':'', f.xgHome>0.6?'sm-xg-hi':'', f.xgAway>0.6?'sm-xg-hi':''),
        mkDetailStat('Pressure', f.pressureHome||0, f.pressureAway||0, Math.max(f.pressureHome||0,f.pressureAway||0)+'% peak',
          Math.max(f.pressureHome||0,f.pressureAway||0)>=68?'alert-press':'',
          (f.pressureHome||0)>=68?'sm-press-hi':'', (f.pressureAway||0)>=68?'sm-press-hi':'','%'),
        mkDetailStat('Danger. Atk', f.dangerousHome||0, f.dangerousAway||0, ((f.dangerousHome||0)+(f.dangerousAway||0))+' total'),
        mkDetailStat('Shots on Target', f.shotsOnTargetHome||0, f.shotsOnTargetAway||0, (f.totalShots||0)+' total'),
        (f.shotsTotalHome||f.shotsTotalAway) ? mkDetailStat('Shots Total', f.shotsTotalHome||0, f.shotsTotalAway||0, ((f.shotsTotalHome||0)+(f.shotsTotalAway||0))+' total') : '',
        (f.shotsOffTargetHome||f.shotsOffTargetAway) ? mkDetailStat('Shots Off Target', f.shotsOffTargetHome||0, f.shotsOffTargetAway||0, ((f.shotsOffTargetHome||0)+(f.shotsOffTargetAway||0))+' total') : '',
      ].filter(Boolean);

      const rightStats = [
        (f.cornersHome||f.cornersAway) ? mkDetailStat('Corners', f.cornersHome||0, f.cornersAway||0, ((f.cornersHome||0)+(f.cornersAway||0))+' total') : '',
        (f.attacksHome||f.attacksAway) ? mkDetailStat('Attacks', f.attacksHome||0, f.attacksAway||0, ((f.attacksHome||0)+(f.attacksAway||0))+' total') : '',
        (f.possessionHome||f.possessionAway) ? mkDetailStat('Possession', f.possessionHome||0, f.possessionAway||0, '�', '', '', '', '%') : '',
        (f.passesHome||f.passesAway) ? mkDetailStat('Passes', f.passesHome||0, f.passesAway||0, ((f.passesHome||0)+(f.passesAway||0))+' total') : '',
        (f.accuratePassesHome||f.accuratePassesAway) ? mkDetailStat('Accurate Passes', f.accuratePassesHome||0, f.accuratePassesAway||0, ((f.accuratePassesHome||0)+(f.accuratePassesAway||0))+' total') : '',
        (f.savesHome||f.savesAway) ? mkDetailStat('Saves', f.savesHome||0, f.savesAway||0, ((f.savesHome||0)+(f.savesAway||0))+' total') : '',
        (f.offsidesHome||f.offsidesAway) ? mkDetailStat('Offsides', f.offsidesHome||0, f.offsidesAway||0, ((f.offsidesHome||0)+(f.offsidesAway||0))+' total') : '',
      ].filter(Boolean);

      return `<div class="sm-row" data-fid="${f.fixtureId}" onclick="smToggleRow(this)">
        <div class="sm-row-hdr">
          <span class="sm-row-minute">${f.minute}'</span>
          <div class="sm-row-teams">
            <span style="flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${esc(f.teamHome)}</span>
            <span class="sm-row-score">${f.goalsHome} � ${f.goalsAway}</span>
            <span style="flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;text-align:right">${esc(f.teamAway)}</span>
          </div>
          <!-- Inline mini stats -->
          <div class="sm-row-inline">
            <div class="sm-inline-stat">
              <span class="sm-inline-lbl">xG</span>
              <span class="sm-inline-val ${f.xgTotal>=1.5?'sm-xg-hi':''}">${f.xgHome.toFixed(1)}�${f.xgAway.toFixed(1)}</span>
              <div class="sm-inline-bar"><div class="sm-inline-bar-h" style="width:${xgHp}%"></div><div style="flex:1;height:100%;background:var(--orange)"></div></div>
            </div>
            <div class="sm-inline-stat">
              <span class="sm-inline-lbl">Press</span>
              <span class="sm-inline-val ${Math.max(f.pressureHome||0,f.pressureAway||0)>=68?'sm-press-hi':''}">${f.pressureHome||0}�${f.pressureAway||0}</span>
              <div class="sm-inline-bar"><div class="sm-inline-bar-h" style="width:${presHp}%"></div><div style="flex:1;height:100%;background:var(--orange)"></div></div>
            </div>
            <div class="sm-inline-stat">
              <span class="sm-inline-lbl">DAngr</span>
              <span class="sm-inline-val">${f.dangerousHome||0}�${f.dangerousAway||0}</span>
              <div class="sm-inline-bar"><div class="sm-inline-bar-h" style="width:${danHp}%"></div><div style="flex:1;height:100%;background:var(--orange)"></div></div>
            </div>
            <div class="sm-inline-stat">
              <span class="sm-inline-lbl">SoT</span>
              <span class="sm-inline-val">${f.shotsOnTargetHome||0}�${f.shotsOnTargetAway||0}</span>
            </div>
          </div>
          <div class="sm-row-sigs">${sigHtml}</div>
          <span class="sm-row-chevron">▼</span>
        </div>
        <div class="sm-row-detail">
          <div style="display:flex;gap:8px;padding:10px 14px;font-size:10px;color:var(--muted);border-bottom:1px solid var(--border)">
            <span style="font-weight:700;color:var(--blue)">${esc(f.teamHome)}</span>
            <span>vs</span>
            <span style="font-weight:700;color:var(--orange)">${esc(f.teamAway)}</span>
            ${sigs.length ? `<span style="margin-left:auto">${sigs.map(s=>`<span class="sm-signal-pill" title="Min ${s.minute}">${esc(s.strategy.replace('SM_',''))}</span>`).join('')}</span>` : ''}
          </div>
          <div class="sm-detail-grid">
            <div class="sm-detail-col">${leftStats.join('')}</div>
            <div class="sm-detail-col">${rightStats.join('')}</div>
          </div>
        </div>
      </div>`;
    });
    cardsEl.innerHTML = `<div class="sm-fixture-list">${rows.join('')}</div>`;
  }

  // Signals log
  const signals = d.signalsFired || [];
  const sigCount = document.getElementById('sm-signals-count');
  const sigEmpty = document.getElementById('sm-signals-empty');
  const sigTbl = document.getElementById('sm-signals-tbl');
  const sigTbody = document.getElementById('sm-signals-tbody');

  sigCount.textContent = signals.length ? `(${signals.length})` : '';
  if (!signals.length) {
    sigEmpty.style.display = '';
    sigTbl.style.display = 'none';
  } else {
    sigEmpty.style.display = 'none';
    sigTbl.style.display = '';
    sigTbody.innerHTML = signals.slice(0, 100).map(s => {
      const t = new Date(s.firedAt);
      return `<tr>
        <td style="color:var(--muted)">${t.toLocaleTimeString('en-GB')}</td>
        <td style="font-weight:600">${esc(s.match)}</td>
        <td style="color:var(--yellow)">${s.minute}'</td>
        <td>${esc(s.score||'�')}</td>
        <td><span class="sm-signal-pill">${esc(s.strategy.replace('SM_',''))}</span></td>
        <td class="${s.xgTotal>1.5?'sm-xg-hi':''}">${(s.xgTotal||0).toFixed(2)}</td>
        <td>${s.xgVelocity!=null?s.xgVelocity.toFixed(3):'�'}</td>
        <td>${s.dangerDelta!=null?'+'+s.dangerDelta:'�'}</td>
      </tr>`;
    }).join('');
  }

  // Strategy reference cards
  renderSmStratCards();

  // Update goal badge and re-render snapshots panel if it's visible
  const totalGoals = (d.fixtures||[]).reduce((n,f)=>n+(f.goalSnapshots||[]).length,0);
  const badge = document.getElementById('sm-goal-count-badge');
  if (badge) badge.textContent = totalGoals > 0 ? `(${totalGoals})` : '';
  if (document.getElementById('sm-panel-goals')?.style.display !== 'none') {
    renderSmGoalSnapshots();
  }
}

function renderSmStratCards() {
  const container = document.getElementById('sm-strat-cards');
  const strategies = [
    { name:'SM_xG_Surge',           desc:'xG velocity burst � rapid expected goals buildup',                     params:[['Min','35�78'],['Max Goals','1'],['xG Vel Min','0.10/min'],['Min xG','0.8']] },
    { name:'SM_Pressure_Wave',       desc:'Sustained pressure index spike � team dominating danger zone',         params:[['Min','40�82'],['Max Goals','1'],['Min Pressure','68'],['Sustained','2 polls']] },
    { name:'SM_Danger_Burst',        desc:'Dangerous attacks burst + shots on target accumulation',              params:[['Min','30�80'],['Max Goals','1'],['Danger Δ','8+'],['Min SoT','4'],['Min xG','0.7']] },
    { name:'SM_Late_xG_Mismatch',    desc:'Late game � high xG but low goals (defence over-performing)',         params:[['Min','65�85'],['Max Goals','1'],['Min xG','1.8']] },
  ];
  container.innerHTML = strategies.map(s => `
    <div class="sm-strat-card">
      <div class="sm-strat-name">⚡ ${esc(s.name.replace('SM_',''))}</div>
      <div class="sm-strat-desc">${esc(s.desc)}</div>
      <div class="sm-strat-params">${s.params.map(([k,v])=>`<span class="sm-param">${esc(k)}: <strong>${esc(v)}</strong></span>`).join('')}</div>
    </div>`).join('');
}

let _smGoalsHistory = [];

function smShowInnerTab(tab) {
  document.getElementById('sm-panel-live').style.display  = tab === 'live'  ? '' : 'none';
  document.getElementById('sm-panel-goals').style.display = tab === 'goals' ? '' : 'none';
  document.getElementById('sm-itab-live').classList.toggle('active',  tab === 'live');
  document.getElementById('sm-itab-goals').classList.toggle('active', tab === 'goals');
  if (tab === 'goals') loadSmGoalsHistory();
}

async function loadSmGoalsHistory() {
  try {
    const r = await fetch('/football/api/goals/history');
    _smGoalsHistory = await r.json();
  } catch(_) { _smGoalsHistory = []; }
  renderSmGoalSnapshots();
}

function _smGoalRow(s, matchLabel) {
  const momH  = s.momentumHome ?? s.pressureHome ?? 0;
  const momA  = s.momentumAway ?? s.pressureAway ?? 0;
  const minTxt = s.minuteDisplay || (s.minute + (s.extraMinute > 0 ? '+'+s.extraMinute : '')) || s.minute + "'";
  const badge = s.preExisting
    ? `<span style="font-size:9px;font-weight:700;padding:2px 5px;border-radius:8px;background:rgba(139,148,158,.12);color:var(--muted);border:1px solid var(--border)">Pre-existing</span>`
    : s.againstMomentum
      ? `<span class="sm-goal-atm">Against Momentum</span>`
      : `<span class="sm-goal-wtm">With Momentum</span>`;
  const ogBadge = s.isOwnGoal ? `<span style="font-size:9px;color:var(--muted)"> OG</span>` : '';
  const xgStr  = (s.xgHome != null) ? `${(s.xgHome||0).toFixed(2)} � ${(s.xgAway||0).toFixed(2)}` : '�';
  const momStr = momH || momA ? `${momH} � ${momA}` : '�';
  const momCls = momH > momA ? 'sm-goal-scorer home' : momA > momH ? 'sm-goal-scorer away' : '';
  return `<div class="sm-goal-snap-row">
    <div class="sm-goal-min">${esc(minTxt)}'</div>
    <div class="sm-goal-scorer ${s.scoringTeam}">${esc(matchLabel || s.match || '�')}${ogBadge}</div>
    <div class="sm-goal-newscore">${s.scoreHome} � ${s.scoreAway}</div>
    <div class="sm-goal-stat">
      <span class="sm-goal-stat-lbl">xG H�A</span>
      <span class="sm-goal-stat-val">${xgStr}</span>
    </div>
    <div class="sm-goal-stat">
      <span class="sm-goal-stat-lbl">Momentum H�A</span>
      <span class="sm-goal-stat-val ${momCls}">${momStr}</span>
    </div>
    <div>${badge}</div>
  </div>`;
}

function renderSmGoalSnapshots() {
  const wrap = document.getElementById('sm-goal-snaps-wrap');

  // ── Live session goals (from smData) ──────────────────────────────────────
  const liveGroups = (smData?.fixtures || [])
    .map(f => ({ f, snaps: (f.goalSnapshots || []) }))
    .filter(g => g.snaps.length > 0);

  const totalLive = liveGroups.reduce((n, g) => n + g.snaps.length, 0);
  document.getElementById('sm-goal-count-badge').textContent =
    totalLive > 0 ? `(${totalLive})` : '';

  const hdr = `<div class="sm-goal-snap-hdr">
    <span>Min</span><span>Scorer</span><span>Score</span>
    <span>xG (H�A)</span><span>Momentum (H�A)</span><span>Context</span>
  </div>`;

  let html = '';

  if (liveGroups.length) {
    html += `<div style="font-size:11px;font-weight:700;color:var(--text);margin-bottom:8px">This Session</div>`;
    html += liveGroups.map(({ f, snaps }) => {
      const rows = snaps.map(s => {
        const [home, away] = [esc(f.teamHome), esc(f.teamAway)];
        const scorer = s.scoringTeam === 'home' ? home : away;
        return _smGoalRow(s, scorer);
      }).join('');
      return `<div class="sm-goal-group">
        <div class="sm-goal-group-hdr">
          <div class="sm-goal-group-teams">
            <span style="color:var(--blue)">${esc(f.teamHome)}</span>
            <span class="sm-goal-group-score">${f.goalsHome} � ${f.goalsAway}</span>
            <span style="color:var(--orange)">${esc(f.teamAway)}</span>
          </div>
          <span style="font-size:10px;color:var(--muted)">${snaps.length} goal${snaps.length!==1?'s':''} � min ${f.minute}'</span>
        </div>${hdr}${rows}
      </div>`;
    }).join('');
  }

  // ── Historic goals (from sportmonks_goals.json) ───────────────────────────
  if (_smGoalsHistory.length) {
    // Group by match name
    const byMatch = {};
    for (const s of _smGoalsHistory) {
      const key = s.match || s.fixtureId || 'Unknown';
      if (!byMatch[key]) byMatch[key] = { match: key, snaps: [], date: s.detectedAt };
      byMatch[key].snaps.push(s);
      if (s.detectedAt > byMatch[key].date) byMatch[key].date = s.detectedAt;
    }
    const matchGroups = Object.values(byMatch).sort((a,b) => b.date.localeCompare(a.date));

    html += `<div style="font-size:11px;font-weight:700;color:var(--text);margin:16px 0 8px">All Captured Goals (${_smGoalsHistory.length})</div>`;
    html += matchGroups.map(({ match, snaps }) => {
      const parts = match.split(' vs ');
      const [hName, aName] = parts.length === 2 ? parts : [match, ''];
      const rows = snaps
        .slice().sort((a,b) => (a.minute||0) - (b.minute||0))
        .map(s => {
          const scorer = s.scoringTeam === 'home' ? hName : aName;
          return _smGoalRow(s, esc(scorer));
        }).join('');
      const detectedDate = new Date(snaps[snaps.length-1]?.detectedAt || snaps[0]?.detectedAt);
      const dateStr = detectedDate.toLocaleDateString('en-GB',{day:'numeric',month:'short',hour:'2-digit',minute:'2-digit'});
      return `<div class="sm-goal-group">
        <div class="sm-goal-group-hdr">
          <div class="sm-goal-group-teams">
            <span style="color:var(--blue)">${esc(hName)}</span>
            ${aName ? `<span class="sm-goal-group-score">vs</span><span style="color:var(--orange)">${esc(aName)}</span>` : ''}
          </div>
          <span style="font-size:10px;color:var(--muted)">${snaps.length} goal${snaps.length!==1?'s':''} � ${dateStr}</span>
        </div>${hdr}${rows}
      </div>`;
    }).join('');
  }

  if (!html) {
    wrap.innerHTML = '<div style="font-size:12px;color:var(--muted);padding:30px;text-align:center">No goal snapshots yet � captured automatically when a goal is detected during polling.</div>';
    return;
  }
  wrap.innerHTML = html;
}

// ─── Football AI Analysis ──────────────────────────────────────────────────────
let _fbAiHistory = [];
let _fbAiHistIdx = -1;

async function loadFootballAiHistory() {
  try {
    const r = await fetch('/football/api/analysis/history');
    _fbAiHistory = await r.json();
    renderFbAiHistoryList();
    if (_fbAiHistory.length > 0 && _fbAiHistIdx < 0) {
      _fbAiHistIdx = 0;
      _fbAiShowRun(_fbAiHistory[0], 0);
    }
  } catch(e) {
    document.getElementById('fb-ai-history-list').innerHTML = '<div style="padding:16px;text-align:center;color:var(--muted);font-size:11px">Failed to load history</div>';
  }
}

function renderFbAiHistoryList() {
  const el = document.getElementById('fb-ai-history-list');
  if (!_fbAiHistory.length) {
    el.innerHTML = '<div style="padding:20px;text-align:center;color:var(--muted);font-size:11px">No runs yet � click Run Analysis to start</div>';
    return;
  }
  el.innerHTML = _fbAiHistory.map((run, i) => {
    const d = new Date(run.generatedAt);
    const when = d.toLocaleDateString('en-GB',{day:'numeric',month:'short'}) + ' ' + d.toLocaleTimeString('en-GB',{hour:'2-digit',minute:'2-digit'});
    const snap = run.dataSnapshot || {};
    const sr = snap.won != null && snap.lost != null && snap.won+snap.lost > 0
      ? ((snap.won/(snap.won+snap.lost))*100).toFixed(0)+'%' : '';
    return `<div class="fb-ai-hist-item${i===_fbAiHistIdx?' active':''}" onclick="showFbAiHistoryRun(${i})">
      <div class="fb-ai-hist-when">${esc(when)}</div>
      <div class="fb-ai-hist-meta">${snap.totalBets||'?'} bets${sr?' � '+sr+' SR':''}${snap.totalPl!=null?' � '+(snap.totalPl>=0?'+':'')+snap.totalPl.toFixed(2)+'pts':''}</div>
    </div>`;
  }).join('');
}

function showFbAiHistoryRun(idx) {
  _fbAiHistIdx = idx;
  _fbAiShowRun(_fbAiHistory[idx], idx);
  renderFbAiHistoryList();
}

function _fbAiShowRun(run, idx) {
  const snap = run.dataSnapshot || {};
  const snapEl = document.getElementById('fb-ai-snap');
  const ph = document.getElementById('fb-ai-placeholder');
  const sectEl = document.getElementById('fb-ai-sections');
  const tokEl = document.getElementById('fb-ai-tokens');

  snapEl.style.display = '';
  ph.style.display = 'none';
  sectEl.style.display = '';

  document.getElementById('fb-ai-snap-bets').textContent = snap.totalBets ?? '�';
  document.getElementById('fb-ai-snap-won').textContent = snap.won ?? '�';
  document.getElementById('fb-ai-snap-lost').textContent = snap.lost ?? '�';
  const plEl = document.getElementById('fb-ai-snap-pl');
  if (snap.totalPl != null) {
    plEl.textContent = (snap.totalPl >= 0 ? '+' : '') + snap.totalPl.toFixed(2);
    plEl.style.color = snap.totalPl >= 0 ? 'var(--green)' : 'var(--red)';
  } else { plEl.textContent = '�'; }

  sectEl.innerHTML = _fbAiRenderMarkdown(run.analysis || '');

  const u = run.tokenUsage || {};
  if (u.input_tokens || u.output_tokens) {
    tokEl.style.display = '';
    tokEl.innerHTML = `<span>Generated: ${new Date(run.generatedAt).toLocaleString('en-GB')}</span>`
      + (u.input_tokens   ? `<span>Input: ${u.input_tokens.toLocaleString()} tokens</span>` : '')
      + (u.output_tokens  ? `<span>Output: ${u.output_tokens.toLocaleString()} tokens</span>` : '')
      + (u.cache_read_input_tokens ? `<span style="color:var(--green)">Cache read: ${u.cache_read_input_tokens.toLocaleString()}</span>` : '');
  } else {
    tokEl.style.display = 'none';
  }
  if (run.fromCache) {
    tokEl.style.display = '';
    tokEl.innerHTML = `<span style="color:var(--yellow)">⚡ Served from cache (30min TTL)</span>`;
  }
}

function _fbAiRenderMarkdown(md) {
  const sections = md.split(/\n(?=## )/);
  return sections.map(sec => {
    const headMatch = sec.match(/^## (.+)\n/);
    if (!headMatch) return sec ? `<div class="fb-ai-section"><p>${esc(sec).replace(/\n/g,'<br>')}</p></div>` : '';
    const heading = headMatch[1];
    let body = sec.slice(headMatch[0].length);
    body = body
      .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
      .replace(/✅ KEEP/g, '<span class="fb-ai-verdict verdict-keep">✅ KEEP</span>')
      .replace(/⚠️ TUNE/g, '<span class="fb-ai-verdict verdict-tune">⚠️ TUNE</span>')
      .replace(/❌ DROP/g, '<span class="fb-ai-verdict verdict-drop">❌ DROP</span>');
    const isList = body.trim().startsWith('-') || /^\d+\./m.test(body.trim());
    let content;
    if (isList) {
      const lines = body.split('\n').filter(l => l.trim());
      const isOrdered = /^\d+\./.test(lines[0]?.trim());
      const items = lines.filter(l => /^[-\d]/.test(l.trim())).map(l => `<li>${l.replace(/^[-\d.]+\s*/,'').trim()}</li>`).join('');
      content = isOrdered ? `<ol>${items}</ol>` : `<ul>${items}</ul>`;
    } else {
      content = body.split('\n\n').filter(p => p.trim()).map(p => `<p>${p.replace(/\n/g,'<br>')}</p>`).join('');
    }
    return `<div class="fb-ai-section"><h2>${esc(heading)}</h2>${content}</div>`;
  }).join('');
}

async function runFootballAi(force = false) {
  const btn = document.getElementById('fb-ai-run-btn');
  if (btn) { btn.disabled = true; btn.textContent = 'Running�'; }
  document.getElementById('fb-ai-placeholder').style.display = '';
  document.getElementById('fb-ai-sections').style.display = 'none';
  document.getElementById('fb-ai-snap').style.display = 'none';
  document.getElementById('fb-ai-tokens').style.display = 'none';
  document.getElementById('fb-ai-placeholder').querySelector('div:nth-child(4)').textContent = 'Analysing with Claude AI� (may take 30�60s)';

  try {
    const r = await fetch(`/football/api/analysis/run${force ? '?force=1' : ''}`);
    const result = await r.json();
    if (result.error) {
      document.getElementById('fb-ai-placeholder').querySelector('div:nth-child(4)').innerHTML = `<span style="color:var(--red)">${esc(result.error)}</span>`;
      return;
    }
    _fbAiHistory.unshift(result);
    _fbAiHistIdx = 0;
    renderFbAiHistoryList();
    _fbAiShowRun(result, 0);
  } catch(e) {
    document.getElementById('fb-ai-placeholder').querySelector('div:nth-child(4)').innerHTML = `<span style="color:var(--red)">Error: ${esc(e.message)}</span>`;
  } finally {
    if (btn) { btn.disabled = false; btn.textContent = 'Run Analysis'; }
  }
}

connectSSE();reload();setInterval(reload,30000);
</script>
</body>
</html>



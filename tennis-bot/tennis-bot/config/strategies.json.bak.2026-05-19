        },
        "entry": {
          "player": "winner",
          "side": "BACK",
          "minOdds": 1.5,
          "maxOdds": 3
        },
        "exit": {
          "type": "none"
        }
      }
    },
    {
      "name": "Strat12",
      "description": "Strategy E (184-match study, -2.9% EV n=50, NEGATIVE). Pre-match favourite lost S1, won S2 — back them into S3. Included for completeness; market fairly prices this scenario. Recommend leaving DISABLED unless used as a paper-trade control.",
      "enabled": true,
      "filters": {
        "surfaces": [
          "hard",
          "clay",
          "grass"
        ]
      },
      "staking": {
        "stakeGBP": 2
      },
      "exit": {
        "type": "none"
      },
      "backtest": {
        "trigger": {
          "setNumber": 2,
          "loserMustBe": "B",
          "requireSplitSets": true,
          "allowedSetScores": [
            "6-4",
            "6-3",
            "6-2",
            "6-1",
            "6-0",
            "7-5",
            "7-6"
          ],
          "preMatchOddsWinner": {
            "min": 1.01,
            "max": 1.99
          }
        },
        "entry": {
          "player": "winner",
          "side": "BACK",
          "minOdds": 1.01,
          "maxOdds": 3

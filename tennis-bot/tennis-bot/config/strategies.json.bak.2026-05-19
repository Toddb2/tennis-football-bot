    {
      "name": "Strat5",
      "description": "Both players 1.8-2.2 pre-match — back highest-momentum player at start of set 3. Experimental.",
      "enabled": true,
      "filters": {
        "surfaces": [
          "hard",
          "clay",
          "grass"
        ],
        "momentumFavoursBetPlayer": true,
        "minMatchedVolume": 100000
      },
      "staking": {
        "stakeGBP": 2
      },
      "exit": {
        "type": "none"
      },
      "backtest": {
        "trigger": {
          "setNumber": 2,

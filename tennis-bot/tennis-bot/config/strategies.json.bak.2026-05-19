          "type": "none"
        }
      }
    },
    {
      "name": "Strat7",
      "description": "Strategy D (184-match study, +25.9% EV n=89). At end of Set 2 in a 3-set match (sets 1-1), back whoever just won Set 2. Fires only when sets are split. A-side variant — duplicate as Strat7_B for full coverage.",
      "enabled": true,
      "filters": {
        "surfaces": [
          "hard",
          "clay",
          "grass"
        ]
      },
      "staking": {
        "stakeGBP": 2
      },
      "exit": {
        "type": "none"
      },
      "backtest": {
        "trigger": {
          "setNumber": 2,
          "loserMustBe": "B",
          "requireSplitSets": true,
          "allowedSetScores": [
            "6-4",
            "6-3",
            "6-2",
            "6-1",
            "6-0",
            "7-5",
            "7-6"
          ]
        },
        "entry": {
          "player": "winner",
          "side": "BACK",
          "minOdds": 1.4,
          "maxOdds": 3
        },
        "exit": {
          "type": "none"
        }
      }
    },
    {
      "name": "Strat8",
      "description": "Strategy C (184-match study, +16.6% EV n=49). Pre-match underdog (>2.5) wins Set 1 — back them at end-of-S1 odds 1.5-3.0. A-side variant — duplicate as Strat8_B for B-side mirror.",
      "enabled": true,
      "filters": {
        "surfaces": [
          "hard",
          "clay",
          "grass"
        ]
      },
      "staking": {
        "stakeGBP": 2
      },
      "exit": {
        "type": "none"
      },
      "backtest": {
        "trigger": {
          "setNumber": 1,
          "loserMustBe": "B",
          "allowedSetScores": [
            "6-4",
            "6-3",
            "6-2",
            "6-1",
            "6-0",
            "7-5",
            "7-6"
          ],
          "preMatchOddsWinner": {
            "min": 2.5,
            "max": 99
          }
        },
        "entry": {
          "player": "winner",
          "side": "BACK",
          "minOdds": 1.5,
          "maxOdds": 3
        },
        "exit": {
          "type": "none"
        }
      }
    },
    {
      "name": "Strat9",
      "description": "Strategy B (184-match study, +30.6% EV n=99). Back the player who LOST set 1 if their post-S1 live odds drift to 3.0-10.0. No pre-match filter. A-side variant. (Strat6 was already taken by momentum-set3.)",
      "enabled": true,
      "filters": {
        "surfaces": [
          "hard",
          "clay",
          "grass"
        ]
      },
      "staking": {
        "stakeGBP": 2
      },
      "exit": {
        "type": "none"
      },
      "backtest": {
        "trigger": {
          "setNumber": 1,
          "loserMustBe": "A",
          "allowedSetScores": [
            "4-6",
            "5-7",
            "6-7",
            "3-6",
            "2-6",
            "1-6",
            "0-6"
          ]
        },
        "entry": {
          "player": "loser",
          "side": "BACK",
          "minOdds": 3,
          "maxOdds": 10
        },
        "exit": {
          "type": "none"
        }
      }
    },
    {
      "name": "Strat10",
      "description": "Strategy A (184-match study, +18.4% EV n=22 in odds 1.5-3.0 band only). Back the Set 1 winner who also had >=20pp better 1st-serve-won % than opponent. Filtered to entry odds 1.5-3.0 to skip the unprofitable short-odds subset.",
      "enabled": true,
      "filters": {
        "surfaces": [
          "hard",
          "clay",
          "grass"
        ],
        "minFirstServeWonDiff": 20
      },
      "staking": {
        "stakeGBP": 2
      },
      "exit": {
        "type": "none"
      },
      "backtest": {
        "trigger": {
          "setNumber": 1,
          "loserMustBe": "B",
          "allowedSetScores": [
            "6-4",
            "6-3",
            "6-2",
            "6-1",
            "6-0",
            "7-5",
            "7-6"
          ],
          "filters": {
            "p1MinFirstServeWon": 60,
            "p2MaxFirstServeWon": 40
          }
        },
        "entry": {
          "player": "winner",
          "side": "BACK",
          "minOdds": 1.5,
          "maxOdds": 3
        },
        "exit": {
          "type": "none"
        }
      }
    },
    {
      "name": "Strat11",
      "description": "Strategy F (184-match study, +5.7% EV n=29). Tighter version of Strat7 (D): back S2 winner only when their S2 1st-serve-won % was at least 10pp better than the loser, entry odds 1.5-3.0.",
      "enabled": true,
      "filters": {
        "surfaces": [
          "hard",
          "clay",
          "grass"
        ],
        "minFirstServeWonDiff": 10
      },
      "staking": {
        "stakeGBP": 2

{
  "probabilityModel": {
    "minGamesForLiveStats": 3,
    "fullTrustAfterGames": 10,
    "surfaceAdjustment": true,
    "surfaces": [
      "clay",
      "hard",
      "grass"
    ]
  },
  "signalEngine": {
    "minEdgePercent": 3,
    "minMatchedVolume": 5000,
    "onlyEntryAfterBreak": false
  },
  "liquidity": {
    "minPreMatchVolume": 20000,
    "minVolumeAtTrigger": 100000
  },
  "riskManager": {
    "stakeGBP": 2,
    "maxOpenBets": 10
  },
  "filters": {
    "allowedTournaments": [],
    "blockedTournaments": [
      "ITF"
    ],
    "minOddsToBack": 1.3,
    "maxOddsToBack": 6,
    "minOddsToLay": 1.1,
    "maxOddsToLay": 4,
    "surfaces": [
      "clay",
      "hard",
      "grass"
    ]
  },
  "bfbmExportSettings": {
    "enabled": true
  },
  "telegramSettings": {
    "notifyBetPlaced": true,
    "notifyTradeOut": true,
    "notifyStopLoss": true,
    "notifySystemMatch": true,
    "notifyLowLiquidity": false,
    "notifyError": true
  },
  "systems": [
    {
      "name": "Strat1h",
      "description": "P1 pre-match 1.75-2.3, wins set 1 (6-4/7-5/7-6) — lay P1. Hedge at 1-1.",
      "enabled": true,
      "filters": {
        "surfaces": [
          "hard",
          "clay",
          "grass"
        ]
      },
      "staking": {
        "stakeGBP": 2
      },
      "exit": {
        "type": "set_result",
        "setNumber": 2,
        "hedgeWhen": "bet_player_loses_set"
      },
      "backtest": {
        "trigger": {
          "setNumber": 1,
          "loserMustBe": "B",
          "allowedSetScores": [
            "6-4",
            "7-5",
            "7-6"
          ],
          "preMatchOddsWinner": {
            "min": 1.75,
            "max": 2.3
          }
        },
        "entry": {
          "player": "winner",
          "side": "LAY",
          "minOdds": 1.2,
          "maxOdds": 1.4
        },
        "exit": {
          "type": "none"
        }
      }
    },
    {
      "name": "Strat2",
      "description": "P1 fave (1.1-1.6), loses set 1 (4-6/5-7/6-7) — back P1 to win. No hedge.",
      "enabled": true,
      "filters": {
        "surfaces": [
          "hard",
          "clay",
          "grass"
        ]
      },
      "staking": {
        "stakeGBP": 2
      },
      "exit": {
        "type": "none"
      },
      "backtest": {
        "trigger": {
          "setNumber": 1,
          "loserMustBe": "A",
          "allowedSetScores": [
            "4-6",
            "5-7",
            "6-7"
          ],
          "preMatchOddsLoser": {
            "min": 1.1,
            "max": 1.6
          }
        },
        "entry": {
          "player": "loser",
          "side": "BACK",
          "minOdds": 1.6,
          "maxOdds": 3
        },
        "exit": {
          "type": "none"
        }
      }
    },

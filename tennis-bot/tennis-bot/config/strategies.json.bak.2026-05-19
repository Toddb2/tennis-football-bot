    {
      "name": "Strat6",
      "description": "P1 wins first set with poor stats",
      "enabled": true,
      "filters": {
        "surfaces": [
          "hard",
          "clay",
          "grass"
        ],
        "minMatchedVolume": 100000,
        "momentumFavoursBetPlayer": true
      },
      "staking": {
        "stakeGBP": 2
      },
      "exit": {
        "type": "set_result",
        "setNumber": 2,
        "hedgeWhen": "bet_player_loses_set"
      },
      "backtest": {
        "trigger": {
          "setNumber": 2,
          "allowedSetScores": [
            "6-4",
            "7-5",
            "7-6"
          ],
          "preMatchOddsWinner": {
            "min": 1.2,
            "max": 1.8

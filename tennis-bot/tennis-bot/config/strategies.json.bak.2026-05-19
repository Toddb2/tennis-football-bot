          "allowedSetScores": [
            "6-4",
            "6-3",
            "6-2",
            "6-1",
            "6-0",
            "7-5",
            "7-6"
          ],
          "filters": {
            "p1MinFirstServeWon": 55,
            "p2MaxFirstServeWon": 45
